# Имя контейнера (уникально на хосте)
SITE_CONTAINER_NAME=genshintop_web

# Готовый Docker-образ сайта (публикуется GitHub Actions)
SITE_IMAGE=ghcr.io/idpro1313/genshintop:latest

# Имя роутера Traefik (латиница, без пробелов)
TRAEFIK_ROUTER=genshintop

# Правило Host — обратные кавычки обязательны (как в шаблоне webserver)
TRAEFIK_RULE=Host(`genshintop.ru`) || Host(`www.genshintop.ru`)

# Выдача сертификата Let's Encrypt настраивается в Traefik (webserver), не в этом compose.
# Ошибка tls: unrecognized name — см. deploy/README.md → «Traefik и Let's Encrypt».

# --- Опционально при сборке Astro (переменные окружения билда, не обязательно в deploy/.env контейнера nginx) ---
# Подтверждение кабинетов (meta в <head> через Seo.astro)
# PUBLIC_YANDEX_VERIFICATION=
# PUBLIC_GOOGLE_VERIFICATION=
# PUBLIC_MAILRU_DOMAIN=
# JSON-LD sameAs у Organization: URL через пробел или запятую
# PUBLIC_ORGANIZATION_SAME_AS=https://t.me/yourchannel https://vk.com/yourgroup

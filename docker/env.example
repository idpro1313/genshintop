# Имя контейнера — должно быть уникально на хосте (не копируйте docker/.env с dandangers и др.).
SITE_CONTAINER_NAME=genshintop_web

# Готовый Docker-образ сайта (публикуется GitHub Actions)
SITE_IMAGE=ghcr.io/idpro1313/genshintop:latest

# Имя роутера Traefik (латиница, без пробелов)
TRAEFIK_ROUTER=genshintop

# Правило Host — обратные кавычки обязательны (как в шаблоне webserver)
TRAEFIK_RULE=Host(`genshintop.ru`) || Host(`www.genshintop.ru`)

# Выдача сертификата Let's Encrypt настраивается в Traefik (webserver), не в этом compose.
# Ошибка tls: unrecognized name — см. docker/README.md → «Traefik и Let's Encrypt».

# --- Подтверждение кабинетов вебмастеров (meta в <head> через lib/layout.php) ---
# PUBLIC_YANDEX_VERIFICATION=
# PUBLIC_GOOGLE_SITE_VERIFICATION=
# PUBLIC_MAILRU_DOMAIN=
# JSON-LD sameAs у Organization: URL через пробел или запятую
# PUBLIC_ORGANIZATION_SAME_AS=https://t.me/yourchannel https://vk.com/yourgroup

# --- IndexNow (Яндекс) ---
# Токен по умолчанию задан в lib/IndexNow.php (DEFAULT_KEY) и в public/<key>.txt.
# Host для keyLocation берётся из SITE_URL, если переменная задана; иначе используется genshintop.ru.
# Если хотите свой ключ — укажите его в INDEXNOW_KEY и положите public/<INDEXNOW_KEY>.txt
# с тем же содержимым (требование протокола).
# INDEXNOW_KEY=cfee9df50829202f695cf93c8b24f554
# Запуск пинга после деплоя контента (внутри контейнера или с CLI):
#   php bin/indexnow-ping.php
#   php bin/indexnow-ping.php --match='^https://genshintop\.ru/(news|guides)/' --limit=200

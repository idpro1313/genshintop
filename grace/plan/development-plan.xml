<DevelopmentPlan VERSION="0.1.0">
  <!--
    GRACE development plan — methodology: https://github.com/osovv/grace-marketplace
    Upstream ships Agent Skills + optional CLI (@osovv/grace-cli): grace lint | module find | module show | file show.
    This workspace stores shared XML under grace/** (lifecycle folders), not docs/*.xml; semantic map in docs/AGENTS.md.

    ExecutionPolicy: used by $grace-multiagent-execute / $grace-execute — controller merges edits to the listed
    shared artifacts; workers touch only module sources and module-local tests inside approved write scope.
  -->
  <ArchitectureNotes>
    <!-- High-signal planning notes.

         <objective>What this plan optimizes for.</objective>
         <non-goal>What the implementation should explicitly avoid.</non-goal>
         <risk-1>Key design risk to watch during execution.</risk-1>
    -->
  </ArchitectureNotes>

  <Modules>
    <M-CONTENT-PIPELINE NAME="ContentPipeline" TYPE="UTILITY" LAYER="0" ORDER="1" STATUS="implemented">
      <contract>
        <purpose>Аудит и перенос Markdown из gi-database в src/content с frontmatter и отчётами.</purpose>
        <inputs>
          <param name="gi-database" type="filesystem" />
        </inputs>
        <outputs>
          <param name="src/content" type="markdown" />
          <param name="reports" type="json" />
        </outputs>
        <errors>
          <error code="MISSING_GI" />
        </errors>
      </contract>
      <interface>
        <export-audit PURPOSE="npm run content:audit" />
        <export-migrate PURPOSE="npm run content:migrate" />
        <export-verify PURPOSE="npm run content:verify" />
        <export-audit-guides PURPOSE="npm run content:audit-guides" />
        <export-enrich PURPOSE="npm run content:enrich" />
      </interface>
      <depends>none</depends>
      <target>
        <source>scripts/audit-database.ts</source>
        <source>scripts/process-content.ts</source>
        <source>scripts/verify-migration.ts</source>
        <source>scripts/audit-guides-content.ts</source>
        <source>scripts/enrich-guides.ts</source>
      </target>
      <verification-ref>V-M-CONTENT-PIPELINE</verification-ref>
    </M-CONTENT-PIPELINE>

    <M-OG-PIPELINE NAME="OgImagesPipeline" TYPE="UTILITY" LAYER="0" ORDER="1" STATUS="implemented">
      <contract>
        <purpose>Рендер Open Graph картинок 1200×630 PNG на каждую запись коллекций characters и guides; манифест для getOgImageForEntry.</purpose>
        <inputs>
          <param name="src/content/characters/*.md" type="markdown" />
          <param name="src/content/guides/*.md" type="markdown" />
        </inputs>
        <outputs>
          <param name="public/og/{collection}/{slug}.png" type="png" />
          <param name="src/data/og-manifest.json" type="json" />
        </outputs>
        <errors>
          <error code="SHARP_MISSING" />
        </errors>
      </contract>
      <interface>
        <export-og-generate PURPOSE="npm run og:generate" />
        <export-getOgImageForEntry PURPOSE="src/lib/seo.ts: возвращает путь к PNG или fallback SVG" />
      </interface>
      <depends>M-CONTENT-PIPELINE</depends>
      <target>
        <source>scripts/generate-og-images.ts</source>
        <source>src/lib/seo.ts</source>
        <source>src/data/og-manifest.json</source>
      </target>
      <verification-ref>V-M-OG-PIPELINE</verification-ref>
    </M-OG-PIPELINE>

    <M-WEBSITE NAME="GenshinTopWeb" TYPE="ENTRY_POINT" LAYER="1" ORDER="2" STATUS="implemented">
      <contract>
        <purpose>Статический сайт Astro: маршруты /, /characters, /guides, тематические хабы, кластер /lootbar/* (купоны/прайс из src/data/lootbar.ts с fallback), страницы доверия, SEO (мета, OG, FAQ и HowTo schema.org), RSS `/rss.xml`, sitemap с **lastmod** для динамики (scripts/sitemap-lastmod.mjs + serialize в astro.config.mjs), SearchAction на `/guides?q=`, sitemap, Яндекс.Метрика reachGoal (в т.ч. lootbar_hero_cta, lootbar_coupon_*, lootbar_table_cta, lootbar_calc_cta, lootbar_bottom_*), визуал для молодёжной аудитории в духе Teyvat (Onest+Cinzel, стихийные акценты на карточках, pill-навигация, «звёздный» фон), глобальный футер с версией сайта из VERSION, nginx 404/XML и деплой готового GHCR-образа без сборки на сервере.</purpose>
        <inputs>
          <param name="collections" type="astro-content" />
        </inputs>
        <outputs>
          <param name="dist" type="static-html" />
        </outputs>
        <errors>
          <error code="BUILD_FAIL" />
        </errors>
      </contract>
      <interface>
        <export-build PURPOSE="npm run build" />
        <export-Footer PURPOSE="Глобальный футер сайта с версией из корневого VERSION" />
        <export-LOOTBAR_GENSHIN_TOPUP_URL PURPOSE="Партнёрский URL LootBar.gg по умолчанию" />
        <export-lootbarGenshinTopupUrl PURPOSE="Партнёрский URL с параметром UTM-кампании" />
        <export-editorialTeamPerson PURPOSE="JSON-LD автор Редакция GenshinTop для Article/BlogPosting" />
        <export-lootbarServiceSchema PURPOSE="JSON-LD Service+Offer для коммерческого кластера /lootbar" />
        <export-getOgImageForEntry PURPOSE="Динамический выбор OG-картинки по slug" />
        <export-RegionPage PURPOSE="Шаблон региональных хабов /regions/*" />
        <export-LootBarGlossary PURPOSE="Видимый глоссарий ключевых терминов на /lootbar" />
      </interface>
      <depends>M-CONTENT-PIPELINE, M-OG-PIPELINE</depends>
      <target>
        <source>src/pages</source>
        <source>src/pages/regions</source>
        <source>src/pages/guides/events.astro</source>
        <source>src/pages/guides/tcg.astro</source>
        <source>src/pages/guides/domains.astro</source>
        <source>src/pages/guides/bosses.astro</source>
        <source>src/pages/guides/quests.astro</source>
        <source>src/layouts</source>
        <source>src/components</source>
        <source>src/components/LootBarGlossary.astro</source>
        <source>src/components/RegionPage.astro</source>
        <source>src/data/lootbar.ts</source>
        <source>src/data/og-manifest.json</source>
        <source>src/lib/partners.ts</source>
        <source>src/lib/guide-hub.ts</source>
        <source>src/lib/character-hub.ts</source>
        <source>src/lib/elements.ts</source>
        <source>tailwind.config.mjs</source>
        <source>src/styles/global.css</source>
        <source>public/robots.txt</source>
        <source>astro.config.mjs</source>
        <source>scripts/sitemap-lastmod.mjs</source>
        <source>src/pages/rss.xml.ts</source>
        <source>deploy/nginx-docker.conf</source>
        <source>deploy/genshintop-redirects.conf</source>
        <source>deploy/docker-compose.yml</source>
        <source>deploy/update-from-github.sh</source>
        <source>deploy/SEO-CHECKLIST.md</source>
      </target>
      <verification-ref>V-M-WEBSITE</verification-ref>
    </M-WEBSITE>

    <!-- Modules use unique ID-based tags:
         <M-xxx NAME="..." TYPE="..." LAYER="N" ORDER="N" STATUS="planned">
            <contract>
              <purpose>What this module does</purpose>
              <inputs>
                <param name="..." type="..." />
             </inputs>
             <outputs>
               <param name="..." type="..." />
             </outputs>
             <errors>
               <error code="..." />
             </errors>
           </contract>
            <interface>
              <export-functionName PURPOSE="..." />
            </interface>
            <depends>M-xxx, M-yyy</depends>
            <target>
              <source>path/to/module.ts</source>
              <tests>path/to/module.test.ts</tests>
            </target>
            <observability>
              <log-prefix>[ModuleName]</log-prefix>
              <critical-block>BLOCK_VALIDATE_INPUT</critical-block>
            </observability>
            <verification-ref>V-M-xxx</verification-ref>
            <notes>
              <note-1>Execution or coupling note for reviewers.</note-1>
            </notes>
          </M-xxx>

          Module types: ENTRY_POINT, CORE_LOGIC, DATA_LAYER, UI_COMPONENT, UTILITY, INTEGRATION
          LAYER: dependency depth (0 = no dependencies, 1 = depends on layer 0, etc.)
          ORDER: implementation order within the layer
    -->
  </Modules>

  <DataFlow>
    <DF-CONTENT-MIGRATE NAME="GiToSiteContent" TRIGGER="npm run content:migrate">
      <step-1>Обход gi-database/01_characters и 06_guides</step-1>
      <step-2>Очистка и извлечение метаданных, обогащение ссылками на оружие/артефакты</step-2>
      <step-3>Запись src/content/** и reports/migration-report.json</step-3>
      <step-4>Повторяемая чистка Markdown-артефактов в src/content/guides</step-4>
      <evidence>reports/migration-report.json, успешный astro build</evidence>
    </DF-CONTENT-MIGRATE>

    <DF-LOOTBAR-AFFILIATE NAME="LootBarAffiliateNavigation" TRIGGER="user click">
      <step-1>Пользователь видит пункт навигации, плашку под шапкой или ссылку на главной</step-1>
      <step-2>Переходит на внутренний маршрут /lootbar с SEO и JSON-LD</step-2>
      <step-3>Нажимает внешний CTA на LootBar.gg с параметром aff_short=dandnagers</step-3>
      <evidence>src/pages/lootbar/index.astro, src/data/lootbar.ts, src/components/LootBarPromoBanner.astro, src/lib/partners.ts</evidence>
    </DF-LOOTBAR-AFFILIATE>

    <!-- Data flows use unique ID-based tags:
         <DF-xxx NAME="..." TRIGGER="...">
            <step-1>Description of first step</step-1>
            <step-2>Description of second step</step-2>
            <evidence>Which module, trace, or log markers prove the flow worked</evidence>
          </DF-xxx>
     -->
  </DataFlow>

  <ImplementationOrder>
    <Phase-1 name="SiteMVP" status="done">
      <goal>Рабочий Astro SSG + миграция MVP-контента (персонажи, гайды)</goal>
      <step-1 module="M-CONTENT-PIPELINE" status="done" verification="V-M-CONTENT-PIPELINE">Скрипты аудита и миграции</step-1>
      <step-2 module="M-WEBSITE" status="done" verification="V-M-WEBSITE">Страницы, SEO, деплой-документация</step-2>
    </Phase-1>

    <Phase-5 name="SeoBoostAndSemanticGaps" status="done">
      <goal>SEO-усиление 0.5.0: OG-картинки, обогащение фронтматтера 424 гайдов, новые хабы (events/tcg/domains/bosses/quests), регионы (sumeru/fontaine/natlan), коммерческое усиление /lootbar без скрытого текста, перелинковка, performance (асинхронный Cinzel, отложенная Метрика).</goal>
      <step-1 module="M-OG-PIPELINE" status="done" verification="V-M-OG-PIPELINE">scripts/generate-og-images.ts + og-manifest.json + getOgImageForEntry</step-1>
      <step-2 module="M-CONTENT-PIPELINE" status="done" verification="V-M-CONTENT-PIPELINE">scripts/enrich-guides.ts: транслит slug, фронтматтер, чистка ](#)</step-2>
      <step-3 module="M-WEBSITE" status="done" verification="V-M-WEBSITE">Sitemap-приоритеты, robots Yandex Clean-param, og:image:alt, verification meta, security headers, новые хабы и регионы, перелинковка, glossary и Service-schema на /lootbar</step-3>
    </Phase-5>

    <!-- Phases use unique tags:
         <Phase-1 name="Foundation" status="pending">
            <goal>What this phase proves or unlocks</goal>
            <step-1 module="M-CONFIG" status="pending" verification="V-M-CONFIG">Initialize configuration module</step-1>
            <step-2 module="M-DB" status="pending" verification="V-M-DB">Set up database layer</step-2>
          </Phase-1>

          Phase status: "pending" | "in-progress" | "done"
          Step status: "pending" | "in-progress" | "done"
     -->
  </ImplementationOrder>

  <ExecutionPolicy>
    <!-- Controller-owned shared artifacts (paths relative to project root). -->
    <default-profile>balanced</default-profile>
    <controller-owns>grace/plan/development-plan.xml, grace/knowledge-graph/knowledge-graph.xml, grace/verification/verification-plan.xml</controller-owns>
    <worker-owns>Only module source files and module-local tests inside the approved write scope.</worker-owns>
  </ExecutionPolicy>
</DevelopmentPlan>

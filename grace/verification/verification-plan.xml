<VerificationPlan VERSION="0.1.0">
  <GlobalPolicy>
    <!-- Project-wide verification expectations.

         <log-format>[Module][function][BLOCK_NAME] message</log-format>
         <deterministic-first>true</deterministic-first>
         <module-level-focus>Fast deterministic checks close to the module.</module-level-focus>
         <wave-level-focus>Checks only merged surfaces touched by the current wave.</wave-level-focus>
         <phase-level-focus>Broader integration and regression confidence.</phase-level-focus>
         <redaction>Never log secrets, credentials, raw tokens, or high-risk payloads.</redaction>
    -->
  </GlobalPolicy>

  <CriticalFlows>
    <VF-001 NAME="StaticSiteBuild" USE_CASES="UC-001" DATA_FLOW="DF-CONTENT-MIGRATE" PRIORITY="high">
      <scenario>Сборка Astro после миграции контента</scenario>
      <expected-outcome>npm run build завершается без ошибок, dist/ содержит HTML маршрутов</expected-outcome>
      <required-signals>
        <log-marker>[Build] astro build SUCCESS</log-marker>
      </required-signals>
    </VF-001>
  </CriticalFlows>

  <ModuleVerification>
    <V-M-CONTENT-PIPELINE MODULE="M-CONTENT-PIPELINE" PRIORITY="high">
      <test-files />
      <module-checks>
        <check-1>npm run content:audit — создаёт reports/content-audit.json</check-1>
        <check-2>npm run content:migrate — заполняет src/content и migration-report.json</check-2>
        <check-3>npm run content:verify — сверка счётчиков после полной миграции</check-3>
        <check-4>powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleanup-guides-formatting.ps1 — нормализует Markdown гайдов без удаления смыслового текста</check-4>
      </module-checks>
      <scenarios>
        <scenario-1 kind="success">Отчёты созданы, число выходных файлов согласовано с отчётом</scenario-1>
        <scenario-2 kind="failure">Отсутствует gi-database — скрипт завершается с кодом 1</scenario-2>
      </scenarios>
      <required-log-markers />
      <wave-follow-up>Проверка выборочных статей на артефакты скрапинга</wave-follow-up>
      <phase-follow-up>Удаление gi-database только после ручного подтверждения качества</phase-follow-up>
    </V-M-CONTENT-PIPELINE>

    <V-M-WEBSITE MODULE="M-WEBSITE" PRIORITY="high">
      <test-files />
      <module-checks>
        <check-1>npm run build</check-1>
        <check-2>npx astro check (при необходимости типизации)</check-2>
      </module-checks>
      <scenarios>
        <scenario-1 kind="success">Главная, каталоги и динамические slug-страницы генерируются</scenario-1>
      </scenarios>
      <required-log-markers />
    </V-M-WEBSITE>
  </ModuleVerification>

  <PhaseGates>
    <!-- Larger execution gates.

         <Gate-Phase-1 PHASE="Phase-1">
           <goal>Foundation modules have deterministic local checks and basic observability.</goal>
           <commands>
             <command-1>bun test</command-1>
           </commands>
           <required-evidence>
             <evidence-1>All critical modules have module-local checks defined.</evidence-1>
           </required-evidence>
         </Gate-Phase-1>
    -->
  </PhaseGates>

  <FailurePackets>
    <!-- Optional guidance for future fix loops.

         <packet-template>
           <expected-fields>scenario, expected-evidence, observed-evidence, first-divergent-block, next-action</expected-fields>
         </packet-template>
    -->
  </FailurePackets>
</VerificationPlan>

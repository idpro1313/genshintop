---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';

interface ArticleTimes {
  publishedTime?: string;
  modifiedTime?: string;
}

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  robots?: string;
  articleTimes?: ArticleTimes;
}

const {
  title,
  description,
  canonicalPath,
  ogType,
  jsonLd,
  ogImage,
  ogImageWidth,
  ogImageHeight,
  robots,
  articleTimes,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogType={ogType}
      jsonLd={jsonLd}
      ogImage={ogImage}
      ogImageWidth={ogImageWidth}
      ogImageHeight={ogImageHeight}
      robots={robots}
      articleTimes={articleTimes}
    />
    <!-- Yandex.Metrika counter -->
    <script is:inline type="text/javascript">
      (function (m, e, t, r, i, k, a) {
        m[i] =
          m[i] ||
          function () {
            (m[i].a = m[i].a || []).push(arguments);
          };
        m[i].l = 1 * new Date();
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) {
            return;
          }
        }
        (k = e.createElement(t)),
          (a = e.getElementsByTagName(t)[0]),
          (k.async = 1),
          (k.src = r),
          a.parentNode.insertBefore(k, a);
      })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=109020836', 'ym');

      ym(109020836, 'init', {
        ssr: true,
        webvisor: true,
        clickmap: true,
        ecommerce: 'dataLayer',
        referrer: document.referrer,
        url: location.href,
        accurateTrackBounce: true,
        trackLinks: true,
      });
    </script>
    <!-- /Yandex.Metrika counter -->
  </head>
  <body>
    <noscript>
      <div>
        <img src="https://mc.yandex.ru/watch/109020836" style="position:absolute; left:-9999px;" alt="" />
      </div>
    </noscript>
    <Header />
    <main class="mx-auto min-h-[60vh] max-w-6xl px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>

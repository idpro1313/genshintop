---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { BreadcrumbItem } from '../components/Breadcrumbs.astro';

interface ArticleTimes {
  publishedTime?: string;
  modifiedTime?: string;
}

interface Props {
  title: string;
  description?: string;
  canonicalPath: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbs: BreadcrumbItem[];
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  robots?: string;
  articleTimes?: ArticleTimes;
}

const {
  title,
  description,
  canonicalPath,
  ogType,
  jsonLd,
  breadcrumbs,
  ogImage,
  ogImageWidth,
  ogImageHeight,
  robots,
  articleTimes,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType={ogType}
  jsonLd={jsonLd}
  ogImage={ogImage}
  ogImageWidth={ogImageWidth}
  ogImageHeight={ogImageHeight}
  robots={robots}
  articleTimes={articleTimes}
>
  <Breadcrumbs items={breadcrumbs} />
  <article
    class="prose prose-invert prose-lg max-w-3xl prose-headings:scroll-mt-24 prose-headings:font-display prose-p:leading-relaxed prose-a:break-words prose-a:text-teyvat-mint prose-img:rounded-2xl prose-img:border prose-img:border-white/10 prose-img:shadow-card prose-hr:border-white/10"
  >
    <slot />
  </article>
</BaseLayout>

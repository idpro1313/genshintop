---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LootBarDisclosure from '../../components/LootBarDisclosure.astro';
import LootBarMiniHero from '../../components/LootBarMiniHero.astro';
import LootBarOutboundLink from '../../components/LootBarOutboundLink.astro';
import LootBarPriceTable from '../../components/LootBarPriceTable.astro';
import LootBarPrimogemCalc from '../../components/LootBarPrimogemCalc.astro';
import {
  SITE_URL,
  absoluteUrl,
  breadcrumbListSchema,
  faqPageSchema,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../../lib/seo';
import { lootbarGenshinTopupUrl } from '../../lib/partners';
import { lootbarPrices, lootbarPricesUpdatedAt } from '../../data/lootbar';

const canonicalPath = '/lootbar/kristally-sotvoreniya';
const topupUrl = lootbarGenshinTopupUrl('lootbar_crystals');

const crystalRows = lootbarPrices.filter((r) => /кристалл/i.test(r.product));

const faq = faqPageSchema([
  {
    question: 'Что такое кристаллы сотворения?',
    answer:
      'Премиальная валюта в Genshin Impact, которую можно обменять на камни истока и другие предложения в магазине игры. Условия пакетов на сторонних сайтах смотрите в карточке товара.',
  },
  {
    question: 'Как убедиться, что кристаллы начислились?',
    answer:
      'Проверьте клиент игры и журнал валюты/почту от LootBar. При расхождении обращайтесь в поддержку LootBar с номером заказа.',
  },
]);

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  breadcrumbListSchema([
    { label: 'Главная', href: '/' },
    { label: 'LootBar', href: '/lootbar' },
    { label: 'Кристаллы сотворения', href: canonicalPath },
  ]),
  {
    '@type': 'WebPage',
    '@id': `${absoluteUrl(canonicalPath)}#webpage`,
    name: 'Кристаллы сотворения Genshin Impact — LootBar',
    url: absoluteUrl(canonicalPath),
    isPartOf: { '@id': `${SITE_URL}/#website` },
    ...(lootbarPricesUpdatedAt ? { dateModified: lootbarPricesUpdatedAt } : {}),
  },
  faq,
]);
---

<BaseLayout
  title="Кристаллы сотворения Genshin Impact — купить через LootBar | GenshinTop"
  description="Информация о покупке кристаллов сотворения для Genshin Impact на LootBar.gg: сравнение цен по данным партнёра, оценка молитв, что проверить перед оплатой."
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  hideLootBarPromo={true}
>
  <article class="prose prose-invert prose-lg max-w-5xl">
    <nav class="not-prose mb-6 text-sm text-teyvat-muted">
      <a href="/lootbar" class="text-teyvat-mint hover:underline">← Хаб LootBar</a>
    </nav>
    <LootBarMiniHero
      title="Кристаллы сотворения"
      subtitle="Номиналы и доставка валюты — по правилам LootBar для вашего региона."
    />
    <LootBarDisclosure class="not-prose my-6" compact />
    <div class="not-prose w-full">
      <LootBarPriceTable rows={crystalRows.length > 0 ? crystalRows : []} updatedAt={lootbarPricesUpdatedAt} />
      <LootBarPrimogemCalc prices={crystalRows.length > 0 ? crystalRows : lootbarPrices} updatedAt={lootbarPricesUpdatedAt} />
    </div>
    <p class="text-slate-300">
      Кристаллы — основная премиальная валюта для покупок внутри клиента. Сторонние магазины продают номиналы с
      доставкой на ваш аккаунт согласно их правилам.
    </p>
    <h2>Чек-лист перед заказом</h2>
    <ul>
      <li>Верный регион аккаунта и способ пополнения, который показывает LootBar.</li>
      <li>Номинал и итоговая цена после возможного купона.</li>
      <li>Вы используете официальный домен lootbar.gg или переход с проверенной ссылки.</li>
    </ul>
    <LootBarOutboundLink
      href={topupUrl}
      class="not-prose inline-flex rounded-xl bg-teyvat-accent px-6 py-3 font-semibold text-teyvat-night hover:bg-teyvat-gold"
      reachGoal="lootbar_crystals_cta"
    >
      К пакетам кристаллов на LootBar →
    </LootBarOutboundLink>
  </article>
</BaseLayout>

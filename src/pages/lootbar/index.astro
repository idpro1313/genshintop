---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LootBarBenefitsGrid from '../../components/LootBarBenefitsGrid.astro';
import LootBarCouponCard from '../../components/LootBarCouponCard.astro';
import LootBarDisclosure from '../../components/LootBarDisclosure.astro';
import LootBarOutboundLink from '../../components/LootBarOutboundLink.astro';
import LootBarPriceTable from '../../components/LootBarPriceTable.astro';
import LootBarPrimogemCalc from '../../components/LootBarPrimogemCalc.astro';
import LootBarStepsList from '../../components/LootBarStepsList.astro';
import {
  lootbarCoupons,
  lootbarHowToStepTexts,
  lootbarMaxDiscountPercent,
  lootbarPrices,
  lootbarPricesUpdatedAt,
} from '../../data/lootbar';
import { lootbarGenshinTopupUrl } from '../../lib/partners';
import {
  SITE_URL,
  absoluteUrl,
  breadcrumbListSchema,
  faqPageSchema,
  howToSchema,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../../lib/seo';

const topupUrl = lootbarGenshinTopupUrl('lootbar_hero');
const topupCrystals = lootbarGenshinTopupUrl('lootbar_bottom_crystals');
const topupWelkin = lootbarGenshinTopupUrl('lootbar_bottom_welkin');
const emptyCouponUrl = lootbarGenshinTopupUrl('lootbar_coupon_empty');

const maxCouponPct =
  lootbarCoupons.length > 0 ? Math.max(...lootbarCoupons.map((c) => c.percent)) : null;

const faqs = [
  {
    question: 'LootBar.gg — официальный магазин HoYoverse?',
    answer:
      'Нет. LootBar.gg — сторонний сервис пополнения. GenshinTop — неофициальный фан-сайт и не представляет miHoYo / HoYoverse.',
  },
  {
    question: 'Где взять промокод на LootBar?',
    answer:
      'Обычно в баннерах акций на сайте, в кабинете или рассылке LootBar. Наличие и срок действия зависят от сервиса и вашего региона — проверьте правила до оплаты.',
  },
  {
    question: 'Промокод LootBar и промокод Genshin Impact — это одно и то же?',
    answer:
      'Нет. Коды из стримов и промо miHoYo активируются на официальном сайте подарков HoYoverse. Купон LootBar применяется при оформлении заказа на lootbar.gg.',
  },
  {
    question: 'Подходит ли это для моего региона (RU/СНГ)?',
    answer:
      'Регион аккаунта и доступные способы оплаты уточняйте на странице заказа LootBar и в подсказках клиента игры. GenshinTop не подтверждает совместимость автоматически.',
  },
  {
    question: 'Чем это отличается от официального магазина?',
    answer:
      'В клиенте и на сайтах HoYoverse вы платите напрямую издателю. У сторонних витрин другие условия, поддержка и юридические риски — см. страницу безопасности в разделе /lootbar.',
  },
  {
    question: 'Кто отвечает за налоги и возвраты?',
    answer:
      'Условия возврата, комиссии и споры — только поддержка LootBar и ваша платёжная система. GenshinTop платежи не обрабатывает и суппорт LootBar не заменяет.',
  },
  {
    question: 'Как работает переход по партнёрской ссылке?',
    answer:
      'Параметр aff_short помечает источник перехода для партнёрской программы. Условия заказа и начисления валюты задаются на стороне LootBar.gg.',
  },
];

const howTo = howToSchema({
  name: 'Как получить и применить купон на LootBar.gg для Genshin Impact',
  description:
    'Общий порядок действий для скидок на стороннем топ-апе. Конкретные поля и тексты на lootbar.gg могут меняться.',
  steps: lootbarHowToStepTexts,
});

const webPageNode: Record<string, unknown> = {
  '@type': 'WebPage',
  '@id': `${absoluteUrl('/lootbar')}#webpage`,
  name: 'Пополнение Genshin Impact через LootBar.gg',
  url: absoluteUrl('/lootbar'),
  isPartOf: { '@id': `${SITE_URL}/#website` },
  description:
    'Хаб партнёрского пополнения Genshin Impact на LootBar.gg: оффер, купоны, сравнение цен (по данным партнёра), шаги и FAQ.',
};
if (lootbarPricesUpdatedAt) webPageNode.dateModified = lootbarPricesUpdatedAt;

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  breadcrumbListSchema([
    { label: 'Главная', href: '/' },
    { label: 'Пополнение через LootBar', href: '/lootbar' },
  ]),
  webPageNode,
  howTo,
  faqPageSchema(faqs),
]);
---

<BaseLayout
  title="Пополнение Genshin Impact — LootBar.gg | GenshinTop"
  description="Хаб партнёрского пополнения Genshin Impact на LootBar.gg: топ-ап, купоны, сравнение цен по данным партнёра, шаги и безопасность. GenshinTop — неофициальный сайт."
  canonicalPath="/lootbar"
  jsonLd={jsonLd}
  hideLootBarPromo={true}
>
  <article class="max-w-5xl">
    <Breadcrumbs
      items={[
        { label: 'Главная', href: '/' },
        { label: 'LootBar', href: '/lootbar' },
      ]}
    />

    <header
      class="not-prose grid gap-8 rounded-2xl border border-white/10 bg-gradient-to-br from-teyvat-accent/20 via-teyvat-night to-teyvat-mint/10 p-6 md:grid-cols-2 md:items-center md:p-10"
    >
      <div>
        <p class="text-sm text-teyvat-muted">Партнёрский раздел · реклама</p>
        <h1 class="mt-2 font-display text-3xl font-bold text-white md:text-4xl">
          Genshin Impact на LootBar.gg — пополнение со скидкой
        </h1>
        <p class="mt-4 max-w-xl text-slate-300">
          Материал для русскоязычных игроков, которые уже рассматривают сторонний топ-ап. Цифры в таблице и купонах
          появятся после согласования с партнёром — без выдуманных процентов.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <LootBarOutboundLink
            href={topupUrl}
            class="inline-flex items-center rounded-xl bg-teyvat-accent px-6 py-3 font-semibold text-teyvat-night shadow-glow transition hover:bg-teyvat-gold"
            reachGoal="lootbar_hero_cta"
          >
            Перейти на LootBar
          </LootBarOutboundLink>
          <a
            href="#lootbar-coupons"
            class="inline-flex items-center rounded-xl border border-white/20 px-6 py-3 font-medium text-white transition hover:border-teyvat-mint/40 hover:bg-white/5"
          >
            Получить купон
          </a>
        </div>
      </div>
      <div class="rounded-2xl border border-teyvat-accent/30 bg-teyvat-night/80 p-6 shadow-inner">
        {lootbarMaxDiscountPercent != null ? (
          <p class="font-display text-3xl font-bold leading-tight text-teyvat-gold md:text-4xl">
            До {lootbarMaxDiscountPercent}% дешевле, чем в игре
          </p>
        ) : (
          <p class="text-xl font-semibold text-slate-200">Скидки и купоны — на витрине LootBar</p>
        )}
        {maxCouponPct != null ? (
          <p class="mt-3 inline-flex rounded-full bg-teyvat-mint/15 px-3 py-1 text-sm font-medium text-teyvat-mint">
            + купон до {maxCouponPct}%
          </p>
        ) : null}
        <p class="mt-4 text-sm text-slate-400">
          Актуальные условия — только на lootbar.gg в момент заказа.
        </p>
      </div>
    </header>

    <LootBarDisclosure compact class="not-prose mt-6" />

    <section class="not-prose mt-12 scroll-mt-24" id="lootbar-coupons" aria-labelledby="lootbar-coupons-heading">
      <h2 id="lootbar-coupons-heading" class="font-display text-2xl font-bold text-white md:text-3xl">
        Купоны и акции
      </h2>
      {
        lootbarCoupons.length > 0 ? (
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {lootbarCoupons.map((c) => (
              <LootBarCouponCard coupon={c} />
            ))}
          </div>
        ) : (
          <div class="mt-6 rounded-2xl border border-dashed border-white/20 bg-white/[0.02] p-8 text-center">
            <p class="text-slate-300">
              Конкретные купоны зависят от текущих акций LootBar — откройте страницу топ-апа и проверьте баннеры и
              раздел акций в кабинете.
            </p>
            <LootBarOutboundLink
              href={emptyCouponUrl}
              class="mt-5 inline-flex rounded-xl bg-teyvat-accent px-6 py-3 font-semibold text-teyvat-night transition hover:bg-teyvat-gold"
              reachGoal="lootbar_coupon_empty"
            >
              Смотреть акции на LootBar
            </LootBarOutboundLink>
          </div>
        )
      }
    </section>

    <LootBarBenefitsGrid />
    <LootBarStepsList steps={lootbarHowToStepTexts} />
    <LootBarPriceTable rows={lootbarPrices} updatedAt={lootbarPricesUpdatedAt} />
    <LootBarPrimogemCalc prices={lootbarPrices} updatedAt={lootbarPricesUpdatedAt} />

    <section class="not-prose mt-12" aria-labelledby="lootbar-topics-heading">
      <h2 id="lootbar-topics-heading" class="font-display text-2xl font-bold text-white md:text-3xl">
        Темы раздела
      </h2>
      <ul class="mt-6 list-none space-y-3 pl-0 text-slate-300">
        <li>
          <a href="/lootbar/kak-popolnit-genshin-impact" class="font-medium text-teyvat-mint hover:underline"
            >Как пополнить Genshin Impact</a
          >
          — пошагово и без обещаний «официальности».
        </li>
        <li>
          <a href="/lootbar/promokod" class="font-medium text-teyvat-mint hover:underline">Промокод LootBar</a>
          — где смотреть скидки и чем отличается от кодов HoYoverse.
        </li>
        <li>
          <a href="/lootbar/kristally-sotvoreniya" class="font-medium text-teyvat-mint hover:underline"
            >Кристаллы сотворения</a
          >
          — номиналы и проверка начисления.
        </li>
        <li>
          <a href="/lootbar/blagoslovenie-luny" class="font-medium text-teyvat-mint hover:underline"
            >Благословение полой луны</a
          >
          — подписка и отличие от разовых паков.
        </li>
        <li>
          <a href="/lootbar/bezopasnost-i-oplata" class="font-medium text-teyvat-mint hover:underline"
            >Безопасность и оплата</a
          >
          — риски сторонних топ-апов и чек-лист перед заказом.
        </li>
      </ul>
    </section>

    <section class="prose prose-invert prose-lg mt-12 max-w-none">
      <h2>Частые вопросы</h2>
      {
        faqs.map((f) => (
          <p>
            <strong>{f.question}</strong> {f.answer}
          </p>
        ))
      }
    </section>

    <div
      class="not-prose mt-14 rounded-2xl border border-teyvat-accent/30 bg-teyvat-accent/10 p-8 text-center md:px-10"
    >
      <p class="text-lg font-semibold text-white">Готовы оформить заказ?</p>
      <p class="mt-2 text-sm text-slate-300">
        Выберите направление и проверьте витрину перед оплатой. Партнёрская программа · aff_short=dandnagers
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <LootBarOutboundLink
          href={topupCrystals}
          class="inline-flex rounded-xl bg-teyvat-accent px-6 py-3 font-semibold text-teyvat-night transition hover:bg-teyvat-gold"
          reachGoal="lootbar_bottom_crystals"
        >
          К пакетам кристаллов
        </LootBarOutboundLink>
        <LootBarOutboundLink
          href={topupWelkin}
          class="inline-flex rounded-xl border border-white/25 px-6 py-3 font-semibold text-white transition hover:border-teyvat-mint/50 hover:bg-white/5"
          reachGoal="lootbar_bottom_welkin"
        >
          Подписка «луна»
        </LootBarOutboundLink>
      </div>
      <p class="mt-4 text-xs text-teyvat-muted">
        <a href="/partnership-disclosure" class="text-teyvat-mint hover:underline">Раскрытие партнёрства</a>
        ·{' '}
        <a href="/guides/economy" class="text-teyvat-mint hover:underline">Экономика и молитвы</a>
      </p>
    </div>
  </article>
</BaseLayout>

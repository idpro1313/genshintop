---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Страница не найдена — GenshinTop';
const description = 'Запрошенный адрес отсутствует на GenshinTop. Перейдите в каталог гайдов или персонажей.';
---

<BaseLayout title={title} description={description} canonicalPath="/404" robots="noindex, nofollow">
  <div class="mx-auto max-w-xl rounded-3xl border border-white/10 bg-white/5 px-8 py-12 text-center">
    <h1 class="font-display text-3xl font-bold text-white">404</h1>
    <p class="mt-4 text-slate-300">
      Такой страницы нет или она была перенесена. Проверьте адрес или начните с главной.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-xl bg-teyvat-accent px-6 py-3 font-semibold text-teyvat-night shadow-glow transition hover:bg-teyvat-gold"
        >На главную</a
      >
      <a
        href="/guides"
        class="rounded-xl border border-white/20 bg-white/5 px-6 py-3 font-medium text-white transition hover:border-teyvat-mint/50"
        >Гайды</a
      >
      <a
        href="/characters"
        class="rounded-xl border border-white/20 bg-white/5 px-6 py-3 font-medium text-white transition hover:border-teyvat-mint/50"
        >Персонажи</a
      >
    </div>
  </div>
</BaseLayout>

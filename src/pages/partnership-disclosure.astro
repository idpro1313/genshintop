---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_URL,
  absoluteUrl,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../lib/seo';

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  {
    '@type': 'WebPage',
    '@id': `${absoluteUrl('/partnership-disclosure')}#webpage`,
    name: 'Раскрытие партнёрства GenshinTop',
    url: absoluteUrl('/partnership-disclosure'),
    isPartOf: { '@id': `${SITE_URL}/#website` },
  },
]);
---

<BaseLayout
  title="Раскрытие партнёрства — GenshinTop"
  description="Как устроены партнёрские ссылки GenshinTop на LootBar.gg, прозрачность и ограничения ответственности."
  canonicalPath="/partnership-disclosure"
  jsonLd={jsonLd}
>
  <article class="prose prose-invert prose-lg max-w-3xl">
    <h1 class="not-prose font-display text-3xl font-bold text-white">Раскрытие партнёрства</h1>
    <p>
      На GenshinTop размещены партнёрские материалы по пополнению Genshin Impact через сервис{' '}
      <strong>LootBar.gg</strong>. При переходе по партнёрской ссылке и совершении оплаты GenshinTop может получать
      вознаграждение по правилам партнёрской программы LootBar.
    </p>
    <h2>Что это значит для вас</h2>
    <ul>
      <li>Цену и условия заказа определяет LootBar на момент покупки.</li>
      <li>GenshinTop <strong>не обрабатывает платежи</strong> и не имеет доступа к вашему аккаунту игры.</li>
      <li>LootBar — <strong>не официальный</strong> магазин HoYoverse; альтернатива — покупки в клиенте игры.</li>
      <li>Технический параметр <code class="rounded bg-black/30 px-1">aff_short=dandnagers</code> обозначает наш партнёрский канал на стороне LootBar.</li>
    </ul>
    <h2>Маркировка</h2>
    <p>
      Плашка под шапкой сайта и раздел <a href="/lootbar">/lootbar</a> содержат пометку о партнёрстве и ссылку на это
      раскрытие. Внешние ссылки на витрину помечены атрибутом <code class="rounded bg-black/30 px-1">rel=&quot;sponsored&quot;</code>.
    </p>
    <p>
      <a href="/lootbar">Перейти к хабу LootBar</a>
      {' · '}
      <a href="/editorial-policy">Редакционная политика</a>
    </p>
  </article>
</BaseLayout>

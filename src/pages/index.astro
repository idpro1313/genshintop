---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterCard from '../components/CharacterCard.astro';
import GuideCard from '../components/GuideCard.astro';
import { getCollection } from 'astro:content';
import { contentSlugFromId } from '../lib/slug';
import { jsonLdGraph, publisherOrganization, webSiteNode } from '../lib/seo';
import type { GuideCategory } from '../lib/guide-taxonomy';
import {
  effectiveGuideAudience,
  effectiveGuideGameVersion,
  effectiveGuideStatus,
  effectiveGuideTopic,
} from '../lib/guide-taxonomy';

const characters = (await getCollection('characters'))
  .filter((e) => !e.data.sourceSlug.startsWith('_placeholder'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name, 'ru'));

const guides = (await getCollection('guides'))
  .filter((e) => !e.data.sourceSlug.startsWith('_placeholder'))
  .sort((a, b) => {
    const da = (a.data.updatedAt ?? a.data.date)?.getTime() ?? 0;
    const db = (b.data.updatedAt ?? b.data.date)?.getTime() ?? 0;
    return db - da;
  });

const featuredChars = characters.slice(0, 8);
const latestGuides = guides.slice(0, 6);

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  {
    ...webSiteNode(),
    description:
      'Гайды, персонажи и свежие обновления Genshin Impact по-русски — для тех, кто качает аккаунт и следит за метой.',
  },
]);
---

<BaseLayout
  title="GenshinTop — гайды и база по Genshin Impact"
  description="Билды, баннеры, коды и патчи Genshin Impact на русском. Быстро найти персонажа, разобраться в обновлении и не пропустить выгодное пополнение."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <section
    class="relative overflow-hidden rounded-3xl border border-teyvat-accent/25 bg-gradient-to-br from-teyvat-deep/90 to-teyvat-night px-6 py-14 text-center shadow-card sm:py-16"
  >
    <div class="pointer-events-none absolute inset-0 -z-0 opacity-90 hero-glow"></div>
    <div
      class="pointer-events-none absolute inset-0 -z-0 opacity-30"
      style="background-image: radial-gradient(1.5px 1.5px at 20% 30%, rgba(255,255,255,0.35) 50%, transparent 51%), radial-gradient(1px 1px at 70% 20%, rgba(255,255,255,0.25) 50%, transparent 51%), radial-gradient(1.5px 1.5px at 50% 70%, rgba(78,205,196,0.4) 50%, transparent 51%); background-size: 120px 120px, 180px 180px, 140px 140px;"
      aria-hidden="true"
    >
    </div>
    <p class="relative mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-teyvat-mint/90 sm:text-sm">
      Гайды · билды · баннеры
    </p>
    <h1 class="relative font-display text-4xl font-bold tracking-tight text-white sm:text-5xl">
      Твой <span class="text-gradient-gold">Teyvat</span> без лишней суеты
    </h1>
    <p class="relative mx-auto mt-4 max-w-2xl text-base leading-relaxed text-slate-200 sm:text-lg">
      Собрали персонажей, свежие гайды по патчам и коды — чтобы меньше гуглить и больше играть. Нужен топ-ап?
      <a
        href="/lootbar"
        class="font-semibold text-teyvat-mint underline decoration-teyvat-mint/40 underline-offset-2 hover:text-teyvat-gold hover:decoration-teyvat-gold/50"
        data-reach-goal="lootbar_home_hero_link">LootBar.gg</a
      >
      — скидки и промо на кристаллы и луну в пару кликов (партнёрский раздел).
    </p>
    <div class="relative mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/characters"
        class="min-h-[48px] rounded-full bg-gradient-to-r from-teyvat-accent to-amber-500 px-8 py-3 font-bold text-teyvat-night shadow-glow transition hover:brightness-110"
        >К персонажам</a
      >
      <a
        href="/guides"
        class="min-h-[48px] rounded-full border border-white/25 bg-white/10 px-8 py-3 font-bold text-white backdrop-blur-sm transition hover:border-teyvat-mint/60 hover:bg-white/15"
        >К гайдам</a
      >
    </div>
  </section>

  {
    featuredChars.length > 0 ? (
      <section class="mt-16">
        <div class="mb-6 flex items-end justify-between gap-4">
          <h2 class="font-display text-2xl font-semibold text-white">Персонажи</h2>
          <a href="/characters" class="text-sm text-teyvat-mint hover:underline">
            Все персонажи →
          </a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {featuredChars.map((e) => (
            <CharacterCard
              name={e.data.name}
              slug={contentSlugFromId(e.id)}
              element={e.data.element}
              weapon={e.data.weapon}
              rarity={e.data.rarity}
              rating={e.data.rating}
            />
          ))}
        </div>
      </section>
    ) : null
  }

  <section class="mt-16 rounded-2xl border border-teyvat-accent/20 bg-white/[0.05] p-6 shadow-[0_0_40px_rgba(232,180,69,0.08)] md:p-8">
    <h2 class="font-display text-2xl text-white">Пополнить аккаунт без переплаты</h2>
    <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-200">
      Честный партнёрский гайд: как купить{' '}
      <a href="/lootbar/kristally-sotvoreniya" class="font-medium text-teyvat-mint hover:underline">
        Кристаллы Сотворения
      </a>{' '}
      или{' '}
      <a href="/lootbar/blagoslovenie-luny" class="font-medium text-teyvat-mint hover:underline">
        Благословение Полой Луны
      </a>{' '}
      через LootBar.gg дешевле, чем в клиенте, плюс промокоды и безопасность — всё в одном месте.
    </p>
    <ul class="mt-4 grid gap-2 text-sm md:grid-cols-2">
      <li>
        <a href="/lootbar" class="text-teyvat-mint hover:underline">
          Хаб LootBar — пополнение Genshin Impact
        </a>
      </li>
      <li>
        <a href="/lootbar/kak-popolnit-genshin-impact" class="text-teyvat-mint hover:underline">
          Как пополнить Genshin Impact пошагово
        </a>
      </li>
      <li>
        <a href="/lootbar/promokod" class="text-teyvat-mint hover:underline">
          Промокод LootBar для скидки
        </a>
      </li>
      <li>
        <a href="/partnership-disclosure" class="text-teyvat-muted hover:underline">
          Раскрытие партнёрства
        </a>
      </li>
    </ul>
  </section>

  {
    latestGuides.length > 0 ? (
      <section class="mt-16">
        <div class="mb-6 flex items-end justify-between gap-4">
          <h2 class="font-display text-2xl font-semibold text-white">Свежие гайды</h2>
          <a href="/guides" class="text-sm text-teyvat-mint hover:underline">
            Все гайды →
          </a>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {latestGuides.map((g) => {
            const slug = contentSlugFromId(g.id);
            const fileHint = `${slug}.md`;
            const cat = g.data.category as GuideCategory;
            return (
              <GuideCard
                title={g.data.title}
                slug={slug}
                category={g.data.category}
                topic={effectiveGuideTopic(g.data.topic, cat, fileHint)}
                status={effectiveGuideStatus(g.data.status, cat, g.data.date, slug)}
                audience={effectiveGuideAudience(g.data.audience, cat)}
                gameVersion={effectiveGuideGameVersion(g.data.gameVersion, slug)}
                date={g.data.date}
                updatedAt={g.data.updatedAt}
                summary={g.data.summary}
              />
            );
          })}
        </div>
      </section>
    ) : null
  }
</BaseLayout>

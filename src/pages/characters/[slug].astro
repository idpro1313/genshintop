---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { contentSlugFromId } from '../../lib/slug';
import { elementRu } from '../../lib/elements';
import {
  SITE_URL,
  absoluteUrl,
  breadcrumbListSchema,
  cleanMetaDescription,
  DEFAULT_OG_IMAGE_PATH,
  editorialTeamPerson,
  getOgImageForEntry,
  jsonLdGraph,
  publisherOrganization,
} from '../../lib/seo';

export async function getStaticPaths() {
  const list = await getCollection('characters');
  return list.map((entry) => ({
    params: { slug: contentSlugFromId(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const slug = contentSlugFromId(entry.id);
const canonicalPath = `/characters/${slug}`;

const fallbackDescription = `${entry.data.name} — ${elementRu(entry.data.element)}, ${entry.data.weapon}. Гайд и описание в GenshinTop.`;
const description = cleanMetaDescription(entry.data.title, fallbackDescription);
const ogImage = getOgImageForEntry('characters', slug);
const ogImageAlt = `${entry.data.name} — ${elementRu(entry.data.element)}, ${entry.data.weapon} | GenshinTop`;

const articleId = `${absoluteUrl(canonicalPath)}#article`;

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  breadcrumbListSchema([
    { label: 'Главная', href: '/' },
    { label: 'Персонажи', href: '/characters' },
    { label: entry.data.name, href: canonicalPath },
  ]),
  {
    '@type': 'Article',
    '@id': articleId,
    headline: entry.data.name,
    description,
    inLanguage: 'ru-RU',
    url: absoluteUrl(canonicalPath),
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': absoluteUrl(canonicalPath),
    },
    image: [absoluteUrl(ogImage)],
    author: { '@id': `${SITE_URL}/#editorial-team` },
    publisher: { '@id': `${SITE_URL}/#organization` },
    about: {
      '@type': 'Thing',
      name: entry.data.name,
      description: `${elementRu(entry.data.element)}, ${entry.data.weapon}. Персонаж Genshin Impact.`,
    },
  },
  editorialTeamPerson(),
]);

const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'Персонажи', href: '/characters' },
  { label: entry.data.name, href: canonicalPath },
];

const allGuides = await getCollection('guides');
const relatedGuideSlugs = entry.data.relatedGuides ?? [];
const relatedGuides = relatedGuideSlugs
  .map((s) => allGuides.find((g) => contentSlugFromId(g.id) === s))
  .filter((g): g is (typeof allGuides)[number] => Boolean(g))
  .slice(0, 12);
---

<ArticleLayout
  title={entry.data.title ?? entry.data.name}
  description={description}
  canonicalPath={canonicalPath}
  ogType="article"
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
>
  <header class="mb-8 border-b border-white/10 pb-6">
    <p class="text-sm text-teyvat-muted">
      <span class="text-teyvat-gold">{elementRu(entry.data.element)}</span>
      {' · '}
      {entry.data.weapon}
      {
        entry.data.rarity ? (
          <>
            {' · '}
            <span class="text-amber-200/90">{'★'.repeat(entry.data.rarity)}</span>
          </>
        ) : null
      }
      {
        entry.data.rating ? (
          <>
            {' · '}
            Рейтинг: {entry.data.rating}
          </>
        ) : null
      }
    </p>
    <h1 class="mt-2 font-display text-4xl font-bold text-white">{entry.data.name}</h1>
  </header>

  <Content />

  {
    relatedGuides.length > 0 ? (
      <nav class="mt-12 border-t border-white/10 pt-8" aria-label="Гайды по персонажу">
        <h2 class="font-display text-xl text-teyvat-gold">Гайды и материалы по персонажу</h2>
        <ul class="mt-4 grid list-none grid-cols-1 gap-2 p-0 sm:grid-cols-2">
          {relatedGuides.map((g) => (
            <li>
              <a
                href={`/guides/${contentSlugFromId(g.id)}`}
                class="block rounded-lg border border-white/10 bg-white/5 px-3 py-2 transition hover:border-teyvat-mint/40 hover:bg-white/10"
              >
                <span class="block font-medium text-white">{g.data.title}</span>
                {g.data.summary ? (
                  <span class="mt-0.5 line-clamp-2 block text-xs text-teyvat-muted">
                    {g.data.summary}
                  </span>
                ) : null}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    ) : null
  }

  {
    entry.data.relatedWeapons?.length || entry.data.relatedArtifacts?.length ? (
      <aside class="mt-12 rounded-2xl border border-white/10 bg-white/5 p-6">
        <h2 class="font-display text-xl text-teyvat-gold">Связанное снаряжение из базы</h2>
        {entry.data.relatedWeapons?.length ? (
          <div class="mt-4">
            <h3 class="text-sm font-medium text-slate-300">Упоминания в оружии</h3>
            <ul class="mt-2 list-inside list-disc text-sm text-teyvat-muted">
              {entry.data.relatedWeapons.slice(0, 8).map((w) => (
                <li>{w}</li>
              ))}
            </ul>
          </div>
        ) : null}
        {entry.data.relatedArtifacts?.length ? (
          <div class="mt-4">
            <h3 class="text-sm font-medium text-slate-300">Упоминания в артефактах</h3>
            <ul class="mt-2 list-inside list-disc text-sm text-teyvat-muted">
              {entry.data.relatedArtifacts.slice(0, 8).map((a) => (
                <li>{a}</li>
              ))}
            </ul>
          </div>
        ) : null}
      </aside>
    ) : null
  }
</ArticleLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CharacterCard from '../../components/CharacterCard.astro';
import { getCollection } from 'astro:content';
import { contentSlugFromId } from '../../lib/slug';
import {
  SITE_URL,
  absoluteUrl,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../../lib/seo';

const all = (await getCollection('characters')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, 'ru'),
);

const elements = ['Pyro', 'Hydro', 'Electro', 'Cryo', 'Anemo', 'Geo', 'Dendro'] as const;
const weapons = [
  'Одноручное',
  'Двуручное',
  'Древковое',
  'Катализатор',
  'Лук',
  'Прочее',
] as const;

const pageUrl = absoluteUrl('/characters');
const itemListElement = all.map((e, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: e.data.name,
  item: absoluteUrl(`/characters/${contentSlugFromId(e.id)}`),
}));

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  {
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    name: 'Персонажи Genshin Impact — каталог',
    description:
      'Каталог персонажей Genshin Impact на русском: стихия, оружие, редкость. Удобные фильтры и ссылки на гайды.',
    url: pageUrl,
    isPartOf: { '@id': `${SITE_URL}/#website` },
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: all.length,
      itemListElement,
    },
  },
]);
---

<BaseLayout
  title="Персонажи Genshin Impact"
  description="Каталог персонажей Genshin Impact: стихия, оружие, редкость, рейтинги и ссылки на гайды. Фильтры на странице — для быстрого поиска билда."
  canonicalPath="/characters"
  jsonLd={jsonLd}
>
  <h1 class="font-display text-3xl font-bold text-white">Персонажи Genshin Impact</h1>
  <p class="mt-2 max-w-2xl text-teyvat-muted">
    Полный список героев для подбора билда и состава отряда. Фильтры и поиск работают на вашем устройстве —
    страница отдаётся поисковикам как статический HTML со всеми карточками и ссылками.
  </p>

  <section class="mt-8 rounded-2xl border border-white/10 bg-white/5 p-6 text-slate-300">
    <h2 class="font-display text-lg font-semibold text-white">Ещё по теме</h2>
    <p class="mt-2 text-sm leading-relaxed">
      Свежие материалы по игре — в разделе{' '}
      <a href="/guides" class="text-teyvat-mint underline-offset-2 hover:underline">гайды Genshin Impact</a>
      : баннеры, патчи,{' '}
      <a href="/guides" class="text-teyvat-mint underline-offset-2 hover:underline">тир-листы</a>, советы новичкам и{' '}
      <a href="/guides" class="text-teyvat-mint underline-offset-2 hover:underline">промокоды</a>. На{' '}
      <a href="/" class="text-teyvat-mint underline-offset-2 hover:underline">главной</a> — подборка персонажей и статей.
    </p>
  </section>

  <div class="mt-8 flex flex-col gap-4 lg:flex-row">
    <div class="lg:w-64 lg:shrink-0">
      <label class="mb-2 block text-sm text-teyvat-muted" for="char-search">Поиск по имени</label>
      <input
        id="char-search"
        type="search"
        placeholder="Например, Нахида"
        class="w-full rounded-xl border border-white/15 bg-white/5 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-teyvat-accent focus:outline-none"
        data-char-search
      />

      <p class="mb-2 mt-6 text-sm font-medium text-slate-300">Стихия</p>
      <div class="flex flex-wrap gap-2" data-filter-group="element">
        <button
          type="button"
          data-filter-value=""
          class="rounded-lg border border-white/20 bg-white/5 px-2 py-1 text-xs text-white hover:bg-white/10"
          >Все</button
        >
        {
          elements.map((el) => (
            <button
              type="button"
              data-filter-value={el}
              class="rounded-lg border border-white/15 bg-white/5 px-2 py-1 text-xs text-slate-200 hover:bg-white/10"
            >
              {el}
            </button>
          ))
        }
      </div>

      <p class="mb-2 mt-6 text-sm font-medium text-slate-300">Оружие</p>
      <div class="flex flex-wrap gap-2" data-filter-group="weapon">
        <button
          type="button"
          data-filter-value=""
          class="rounded-lg border border-white/20 bg-white/5 px-2 py-1 text-xs text-white hover:bg-white/10"
          >Все</button
        >
        {
          weapons.map((w) => (
            <button
              type="button"
              data-filter-value={w}
              class="rounded-lg border border-white/15 bg-white/5 px-2 py-1 text-xs text-slate-200 hover:bg-white/10"
            >
              {w}
            </button>
          ))
        }
      </div>

      <p class="mb-2 mt-6 text-sm font-medium text-slate-300">Редкость</p>
      <div class="flex flex-wrap gap-2" data-filter-group="rarity">
        <button
          type="button"
          data-filter-value=""
          class="rounded-lg border border-white/20 bg-white/5 px-2 py-1 text-xs text-white hover:bg-white/10"
          >Все</button
        >
        <button
          type="button"
          data-filter-value="5"
          class="rounded-lg border border-white/15 bg-white/5 px-2 py-1 text-xs text-amber-200 hover:bg-white/10"
          >★★★★★</button
        >
        <button
          type="button"
          data-filter-value="4"
          class="rounded-lg border border-white/15 bg-white/5 px-2 py-1 text-xs text-slate-200 hover:bg-white/10"
          >★★★★</button
        >
      </div>
    </div>

    <div class="min-w-0 flex-1">
      <p class="mb-4 text-sm text-teyvat-muted">
        Показано: <span data-char-count>{all.length}</span> из {all.length}
      </p>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3" id="character-grid">
        {
          all.map((e) => (
            <CharacterCard
              name={e.data.name}
              slug={contentSlugFromId(e.id)}
              element={e.data.element}
              weapon={e.data.weapon}
              rarity={e.data.rarity}
              rating={e.data.rating}
            />
          ))
        }
      </div>
    </div>
  </div>

  <script>
    const search = document.querySelector('[data-char-search]') as HTMLInputElement | null;
    const cards = () => [...document.querySelectorAll('[data-character-card]')] as HTMLElement[];
    const countEl = document.querySelector('[data-char-count]');

    type Group = 'element' | 'weapon' | 'rarity';
    const active: Record<Group, string> = { element: '', weapon: '', rarity: '' };

    function applyFilters() {
      const q = (search?.value ?? '').trim().toLowerCase();
      let visible = 0;
      for (const el of cards()) {
        const name = (el.dataset.name ?? '').toLowerCase();
        const element = el.dataset.element ?? '';
        const weapon = el.dataset.weapon ?? '';
        const rarity = el.dataset.rarity ?? '';
        const okName = !q || name.includes(q);
        const okEl = !active.element || element === active.element;
        const okW = !active.weapon || weapon === active.weapon;
        const okR = !active.rarity || rarity === active.rarity;
        const show = okName && okEl && okW && okR;
        el.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      if (countEl) countEl.textContent = String(visible);
    }

    search?.addEventListener('input', applyFilters);

    for (const group of ['element', 'weapon', 'rarity'] as Group[]) {
      const wrap = document.querySelector(`[data-filter-group="${group}"]`);
      wrap?.addEventListener('click', (ev) => {
        const t = ev.target as HTMLElement;
        const btn = t.closest('button');
        if (!btn) return;
        active[group] = btn.getAttribute('data-filter-value') ?? '';
        applyFilters();
      });
    }
  </script>
</BaseLayout>

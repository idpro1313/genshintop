---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_URL,
  absoluteUrl,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../lib/seo';

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  {
    '@type': 'AboutPage',
    '@id': `${absoluteUrl('/about')}#webpage`,
    name: 'О проекте GenshinTop',
    url: absoluteUrl('/about'),
    isPartOf: { '@id': `${SITE_URL}/#website` },
    description:
      'GenshinTop — комьюнити-ресурс по Genshin Impact: гайды, персонажи, обновления и партнёрский топ-ап LootBar.',
  },
]);
---

<BaseLayout
  title="О проекте GenshinTop"
  description="GenshinTop — гайды, персонажи и обновления Genshin Impact для русскоязычных игроков. Партнёрский раздел с топ-апом через LootBar.gg."
  canonicalPath="/about"
  jsonLd={jsonLd}
>
  <h1 class="font-display text-3xl font-bold text-white">О проекте</h1>
  <nav class="mt-4 flex flex-wrap gap-x-3 gap-y-1 text-sm text-teyvat-muted">
    <a href="/editorial-policy" class="text-teyvat-mint hover:underline">Редакционная политика</a>
    <span aria-hidden="true">·</span>
    <a href="/partnership-disclosure" class="text-teyvat-mint hover:underline">Партнёрство</a>
    <span aria-hidden="true">·</span>
    <a href="/content-updates" class="text-teyvat-mint hover:underline">Обновление контента</a>
    <span aria-hidden="true">·</span>
    <a href="/contacts" class="text-teyvat-mint hover:underline">Контакты</a>
  </nav>
  <div class="mt-6 space-y-4 text-slate-200">
    <p>
      <strong class="text-teyvat-gold">GenshinTop</strong> — неофициальный сайт для тех, кто реально играет в
      <strong>Genshin Impact</strong>: собираем гайды, справку по персонажам и разборы патчей так, чтобы можно было
      быстро найти ответ и вернуться в игру.
    </p>
    <p>
      Мы не связаны с miHoYo / HoYoverse; материалы основаны на открытых данных игры и редакции сайта. Товарные знаки принадлежат правообладателям.
    </p>
    <p>
      Отдельно есть <a href="/lootbar" class="font-medium text-teyvat-mint hover:underline">раздел про пополнение через LootBar.gg</a>
      — партнёрский топ-ап с прозрачными условиями. Как мы относимся к редакции и партнёрству —
      <a href="/editorial-policy" class="text-teyvat-mint hover:underline">политика</a> и{' '}
      <a href="/partnership-disclosure" class="text-teyvat-mint hover:underline">раскрытие партнёрства</a>.
    </p>
  </div>

  <section class="mt-10 rounded-2xl border border-teyvat-accent/20 bg-white/[0.05] p-6">
    <h2 class="font-display text-xl text-white">Топ-ап: кристаллы и луна</h2>
    <p class="mt-2 text-sm text-slate-200">
      Если хочешь пополнить аккаунт дешевле, чем в клиенте — коротко разобрали партнёрский LootBar.gg: как работает топ-ап, как купить{' '}
      <a href="/lootbar/kristally-sotvoreniya" class="text-teyvat-mint hover:underline">
        Кристаллы Сотворения
      </a>{' '}
      и{' '}
      <a href="/lootbar/blagoslovenie-luny" class="text-teyvat-mint hover:underline">
        Благословение Полой Луны
      </a>, что делать с{' '}
      <a href="/lootbar/promokod" class="text-teyvat-mint hover:underline">промокодом</a>{' '}
      и какие есть{' '}
      <a href="/lootbar/bezopasnost-i-oplata" class="text-teyvat-mint hover:underline">
        риски и юридические нюансы
      </a>.
    </p>
  </section>
</BaseLayout>

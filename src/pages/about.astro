---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_URL,
  absoluteUrl,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../lib/seo';

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  {
    '@type': 'AboutPage',
    '@id': `${absoluteUrl('/about')}#webpage`,
    name: 'О проекте GenshinTop',
    url: absoluteUrl('/about'),
    isPartOf: { '@id': `${SITE_URL}/#website` },
    description:
      'GenshinTop — русскоязычный фан-сайт по Genshin Impact: гайды, персонажи, обновления.',
  },
]);
---

<BaseLayout
  title="О проекте GenshinTop"
  description="GenshinTop — русскоязычный фан-сайт по Genshin Impact: гайды, персонажи, обновления."
  canonicalPath="/about"
  jsonLd={jsonLd}
>
  <h1 class="font-display text-3xl font-bold text-white">О проекте</h1>
  <nav class="mt-4 flex flex-wrap gap-x-3 gap-y-1 text-sm text-teyvat-muted">
    <a href="/editorial-policy" class="text-teyvat-mint hover:underline">Редакционная политика</a>
    <span aria-hidden="true">·</span>
    <a href="/partnership-disclosure" class="text-teyvat-mint hover:underline">Партнёрство</a>
    <span aria-hidden="true">·</span>
    <a href="/content-updates" class="text-teyvat-mint hover:underline">Обновление контента</a>
    <span aria-hidden="true">·</span>
    <a href="/contacts" class="text-teyvat-mint hover:underline">Контакты</a>
  </nav>
  <div class="mt-6 space-y-4 text-slate-300">
    <p>
      <strong class="text-teyvat-gold">GenshinTop</strong> — неофициальный информационный ресурс для игроков
      Genshin Impact. Мы собираем и структурируем гайды, описания персонажей и материалы по обновлениям,
      чтобы было проще ориентироваться в мире Teyvat.
    </p>
    <p>
      Контент подготовлен на основе открытых игровых данных и редакционных материалов. Игра
      <strong>Genshin Impact</strong> принадлежит miHoYo / HoYoverse.
    </p>
    <p>
      План развития: расширение разделов (оружие, артефакты, предметы), тематические хабы гайдов и персонажей,
      прозрачное раскрытие партнёрских ссылок на топ-ап (<a href="/lootbar" class="text-teyvat-mint hover:underline">/lootbar</a>), улучшение SEO и мобильного чтения.
    </p>
  </div>
</BaseLayout>

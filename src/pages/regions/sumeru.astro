---
import RegionPage from '../../components/RegionPage.astro';

const SUMERU_NATIVES = new Set([
  'Тигнари',
  'Коллеи',
  'Дори',
  'Сайно',
  'Кандакия',
  'Кандакия (Кандакия)',
  'Нилу',
  'Нахида',
  'Лайла',
  'Файруз',
  'Аль-Хайтам',
  'Дэхья',
  'Алхаитам',
  'Кавэ',
  'Бактриус',
  'Скара',
]);
---

<RegionPage
  slug="sumeru"
  name="Сумеру"
  archon="Кусанали (Нахида)"
  element="Дендро"
  introduction="Сумеру — нация Дендро, дом академии и пустынных племён. Регион вышел в патче 3.0 вместе со стихией Дендро и серией реакций (Цветение, Воспламенение, Кристаллизация и др.)."
  description="Сумеру — регион Genshin Impact с архонтом Дендро Кусанали (Нахидой). Леса академии, пустыня Хадрамавет, цепочки квестов архонтов 3.0–3.8 и ключевые механики реакций Дендро."
  patchRange="Патчи 3.0–3.8"
  archonQuestPath="Глава III · Пролог Сумеру"
  keyMechanics={[
    'Стихия Дендро и реакции: Бутонизация, Воспламенение, Сверхрасцветание, Кристаллизация Дендро',
    'Лес и пустыня — две разных биомы с собственными подземельями и местными существами',
    'Большое древо Уриэль и поток мудрости академии Сумеру',
    'Семь матр: Кшахреварская, Харавтат, Спантамад, Везурваг, Аман, Рукхадеват, Вахумана',
  ]}
  sections={[
    {
      heading: 'Что важно знать про Сумеру',
      body:
        'Сумеру — первый регион, где появилась стихия Дендро. Сюжетная линия завершила квесты Эль Махмуда и предсказания и переворачивает представление об архонтах. Леса наполнены реакциями Дендро, пустыня — отдельной фракцией Эремитов и наследием Дешрет.',
    },
    {
      heading: 'Команды и сборки под Сумеру',
      body:
        'Самые сильные тиммейты под Дендро-реакции — Нахида и Сяо-Хайтам. Команды Бутонизации (Нилу, Коллеи) и Сверхрасцветания (Райдэн, Сайно, Кэ Цин) играют через активный Электро-урон, тогда как Воспламенение усиливается Пиро-героями.',
    },
  ]}
  characterMatcher={(name) => SUMERU_NATIVES.has(name)}
/>

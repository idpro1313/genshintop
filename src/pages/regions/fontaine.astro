---
import RegionPage from '../../components/RegionPage.astro';

const FONTAINE_NATIVES = new Set([
  'Линетт',
  'Линь',
  'Линей',
  'Фремине',
  'Невилетт',
  'Ризли',
  'Шеврёз',
  'Сигевинн',
  'Навия',
  'Фурина',
  'Шарлотта',
  'Клоринда',
  'Эмилия',
  'Эмилия (Эмилия)',
  'Эмили',
  'Эмили (Эмили)',
  'Эмельен',
  'Аэрофиллит',
  'Каплано',
  'Пневма',
  'Усия',
]);
---

<RegionPage
  slug="fontaine"
  name="Фонтейн"
  archon="Фурина"
  element="Гидро"
  introduction="Фонтейн — нация Гидро, технократия с оперой, судом и сложным водным метром. Регион вышел в патче 4.0 и принёс механику плавания и расхождение Пневмы / Усии."
  description="Фонтейн — регион Genshin Impact с архонтом Гидро Фурiной. Опера, суды Невилетта, патчи 4.0–4.8, механика плавания и реакции Пневма / Усия. Гайды и персонажи."
  patchRange="Патчи 4.0–4.8"
  archonQuestPath="Глава IV · Пролог Фонтейна"
  keyMechanics={[
    'Плавание и подводные приключения',
    'Реакция дочерних видов Усия и Пневма во временных подземельях',
    'Архитектура суда и оперы — основа сюжетной линии Фурины и Невилетта',
    'Фонтейнские разломы и геолокации в Эриниссе и под Орлевиской',
  ]}
  sections={[
    {
      heading: 'Что важно знать про Фонтейн',
      body:
        'Фонтейн — самый «современный» регион Тейвата. Технологии Кеяри и юриспруденция выходят на первый план, а в сюжете центральная тема — пророчество о потопе. С точки зрения геймплея Фонтейн впервые позволяет полноценно плавать и нырять, а Усия и Пневма влияют на бой только в локальных зонах.',
    },
    {
      heading: 'Команды и сборки под Фонтейн',
      body:
        'Гидро-композиции с Невилеттом и Фуриной задали мету конца 4.x. Также сильны Замораживание (Айола, Шеврёз отсутствует — Гидро-Крио классика), Парение (Сян Лин + Кокоми) и команды через Усию у Лайни и Линетт. Многие Фонтейн-герои хорошо синергируют между собой.',
    },
  ]}
  characterMatcher={(name) => FONTAINE_NATIVES.has(name)}
/>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import {
  SITE_URL,
  absoluteUrl,
  breadcrumbListSchema,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../../lib/seo';

const canonicalPath = '/regions';
const url = absoluteUrl(canonicalPath);

interface RegionRow {
  slug?: string;
  name: string;
  archon: string;
  element: string;
  patch: string;
  short: string;
}

const regions: RegionRow[] = [
  {
    name: 'Мондштадт',
    archon: 'Барбатос (Венти)',
    element: 'Анемо',
    patch: '1.0',
    short: 'Город свободы и ветра. Стартовая локация и квест Пролога.',
  },
  {
    name: 'Ли Юэ',
    archon: 'Моракс (Чжун Ли)',
    element: 'Гео',
    patch: '1.0',
    short: 'Древняя империя гавани. Архонт Гео и культура династий.',
  },
  {
    name: 'Инадзума',
    archon: 'Райдэн Сёгун',
    element: 'Электро',
    patch: '2.0',
    short: 'Архипелаг, изолированный декретом Вечности. Электро-механики и Татарасуна.',
  },
  {
    slug: 'sumeru',
    name: 'Сумеру',
    archon: 'Кусанали (Нахида)',
    element: 'Дендро',
    patch: '3.0–3.8',
    short: 'Леса и пустыня. Появление стихии Дендро и большие сюжетные арки.',
  },
  {
    slug: 'fontaine',
    name: 'Фонтейн',
    archon: 'Фурина',
    element: 'Гидро',
    patch: '4.0–4.8',
    short: 'Технократическая нация суда и оперы. Механики плавания и Фонтейнские разломы.',
  },
  {
    slug: 'natlan',
    name: 'Натлан',
    archon: 'Мавуика',
    element: 'Пиро',
    patch: '5.0–5.8',
    short: 'Племена огня, ездовые саблезубы и племенные испытания.',
  },
  {
    name: 'Снежная',
    archon: 'Царица',
    element: 'Крио',
    patch: '6.x+',
    short: 'Дом Фатуи. Финальный регион сюжета (по дорожной карте HoYoverse).',
  },
];

const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'Регионы Тейвата', href: canonicalPath },
];

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  breadcrumbListSchema(breadcrumbs),
  {
    '@type': 'CollectionPage',
    '@id': `${url}#webpage`,
    name: 'Регионы Тейвата — карта мира Genshin Impact',
    description:
      'Все регионы Genshin Impact: Мондштадт, Ли Юэ, Инадзума, Сумеру, Фонтейн, Натлан и Снежная. Архонты, стихии, патчи появления и сюжетные арки.',
    url,
    isPartOf: { '@id': `${SITE_URL}/#website` },
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: regions.length,
      itemListElement: regions.map((r, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: r.name,
        item: r.slug ? absoluteUrl(`/regions/${r.slug}`) : url,
      })),
    },
  },
]);
---

<BaseLayout
  title="Регионы Тейвата: карта мира Genshin Impact"
  description="Все регионы Genshin Impact и их архонты: Мондштадт, Ли Юэ, Инадзума, Сумеру, Фонтейн, Натлан, Снежная. Стихии, ключевые механики и сюжетные арки."
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbs} />

  <h1 class="font-display text-3xl font-bold text-white">Регионы Тейвата</h1>
  <p class="mt-2 max-w-2xl text-teyvat-muted">
    Тейват — мир Genshin Impact, разделённый на семь регионов, каждый с собственным архонтом и
    стихией. Здесь короткая карта со ссылками на подробные обзоры регионов и связанные гайды.
  </p>

  <ul class="mt-8 grid list-none grid-cols-1 gap-3 p-0 md:grid-cols-2">
    {
      regions.map((r) => (
        <li class="rounded-2xl border border-white/10 bg-white/5 p-5 transition hover:border-teyvat-mint/30">
          <p class="text-xs uppercase tracking-wide text-teyvat-muted">
            {r.element} · {r.patch}
          </p>
          <p class="mt-1 font-display text-xl text-white">
            {r.slug ? (
              <a href={`/regions/${r.slug}`} class="hover:text-teyvat-mint">
                {r.name}
              </a>
            ) : (
              <span>{r.name}</span>
            )}
          </p>
          <p class="text-sm text-teyvat-gold/90">Архонт: {r.archon}</p>
          <p class="mt-2 text-sm text-slate-300">{r.short}</p>
          {r.slug ? (
            <a href={`/regions/${r.slug}`} class="mt-3 inline-block text-sm text-teyvat-mint hover:underline">
              Подробный обзор →
            </a>
          ) : (
            <p class="mt-3 text-xs text-teyvat-muted">Подробный обзор появится позже.</p>
          )}
        </li>
      ))
    }
  </ul>

  <section class="mt-10 rounded-2xl border border-white/10 bg-white/5 p-6 text-sm text-slate-300">
    <h2 class="font-display text-lg text-white">Связанные разделы</h2>
    <ul class="mt-3 list-disc pl-5">
      <li><a href="/guides/quests" class="text-teyvat-mint hover:underline">Квесты архонтов и сюжет</a></li>
      <li><a href="/guides/patches" class="text-teyvat-mint hover:underline">Обновления Genshin Impact</a></li>
      <li><a href="/characters" class="text-teyvat-mint hover:underline">Все персонажи Genshin Impact</a></li>
    </ul>
  </section>
</BaseLayout>

---
import RegionPage from '../../components/RegionPage.astro';

const NATLAN_NATIVES = new Set([
  'Какавача',
  'Кинич',
  'Мавуика',
  'Цитлали',
  'Часка',
  'Очкан',
  'Иансан',
  'Аютаджи',
  'Варенья',
  'Хоринуси',
  'Атея',
  'Сетхос',
  'Эмили',
  'Шилонен',
  'Шилонен (Шилонен)',
  'Шиленин',
  'Тонатиу',
]);
---

<RegionPage
  slug="natlan"
  name="Натлан"
  archon="Мавуика"
  element="Пиро"
  introduction="Натлан — нация Пиро, мир племён, ездовых саблезубов и племенных испытаний. Регион вышел в патче 5.0 и продолжил тему противостояния силам Бездны."
  description="Натлан — регион Genshin Impact с архонтом Пиро Мавуикой. Племена огня, езда на саблезубах, ночное ядро и патчи 5.0–5.8. Гайды и персонажи."
  patchRange="Патчи 5.0–5.8"
  archonQuestPath="Глава V · Пролог Натлана"
  keyMechanics={[
    'Племена и фракции Натлана: Дерево цветения, Луч полудня, Гром и Молот, Скачущая искра, Ясное сияние, Народ радуги',
    'Ездовые существа (Saurians) и связанные с ними мобилити-механики у местных персонажей',
    'Ночное ядро (Night Realm) и силы, связанные с противостоянием Бездне',
    'Локальные предметы и пайки племён — собственная экономика возвышения',
  ]}
  sections={[
    {
      heading: 'Что важно знать про Натлан',
      body:
        'Натлан построен вокруг племенной структуры и культуры огня. У многих Натлан-героев боевая механика связана с ездовыми существами, которые активны не только в открытом мире, но и в боевых режимах. Сюжет тесно связан с историей Иэрни и противостоянием Бездне.',
    },
    {
      heading: 'Команды и сборки под Натлан',
      body:
        'Натлан-герои сильно играют через Пиро-реакции (Воспламенение в связке с Дендро, классическое Расплавление с Крио). Мавуика — мощный главный ДПС, требующий стака энергии. Цитлали и Иансан часто берут как саппортов под композиции 6.x.',
    },
  ]}
  characterMatcher={(name) => NATLAN_NATIVES.has(name)}
/>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';
import { contentSlugFromId } from '../../lib/slug';
import {
  SITE_URL,
  absoluteUrl,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../../lib/seo';
import type { GuideCategory } from '../../lib/guide-taxonomy';
import {
  effectiveGuideAudience,
  effectiveGuideGameVersion,
  effectiveGuideStatus,
  effectiveGuideTopic,
  guideStatuses,
  guideStatusLabelsRu,
  guideTopicLabelsRu,
  guideTopics,
} from '../../lib/guide-taxonomy';

const all = (await getCollection('guides')).sort((a, b) => {
  const ta = (a.data.updatedAt ?? a.data.date)?.getTime() ?? 0;
  const tb = (b.data.updatedAt ?? b.data.date)?.getTime() ?? 0;
  return tb - ta;
});

const categories = [
  { id: '', label: 'Все типы' },
  { id: 'banner', label: 'Баннеры' },
  { id: 'patch', label: 'Обновления' },
  { id: 'newbie', label: 'Новичкам' },
  { id: 'codes', label: 'Промокоды' },
  { id: 'tier', label: 'Тир-листы' },
  { id: 'hardware', label: 'ПК / железо' },
  { id: 'general', label: 'Прочее' },
];

const topicFilters = [
  { id: '', label: 'Все темы' },
  ...guideTopics.map((id) => ({ id, label: guideTopicLabelsRu[id] })),
];

const statusFilters = [
  { id: '', label: 'Любой статус' },
  ...guideStatuses.map((id) => ({ id, label: guideStatusLabelsRu[id] })),
];

const initialSearchQ = Astro.url.searchParams.get('q') ?? '';

const pageUrl = absoluteUrl('/guides');
const recentForSchema = all.slice(0, 24);
const itemListElement = recentForSchema.map((g, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: g.data.title,
  item: absoluteUrl(`/guides/${contentSlugFromId(g.id)}`),
}));

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  {
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    name: 'Гайды Genshin Impact',
    description:
      'Гайды по Genshin Impact на русском: баннеры молитв, обновления патчей, тир-листы, промокоды и советы новичкам.',
    url: pageUrl,
    isPartOf: { '@id': `${SITE_URL}/#website` },
    mainEntity: {
      '@type': 'ItemList',
      name: 'Недавно обновлённые гайды',
      description: `Фрагмент каталога (${recentForSchema.length} из ${all.length} материалов). Полный перечень URL — в sitemap-index.xml.`,
      numberOfItems: recentForSchema.length,
      itemListElement,
    },
  },
]);
---

<BaseLayout
  title="Гайды Genshin Impact"
  description="Гайды по Genshin Impact: баннеры персонажей и оружия, обновления патчей, советы новичкам, промокоды и тир-листы. Все статьи — отдельные URL для поиска."
  canonicalPath="/guides"
  jsonLd={jsonLd}
>
  <h1 class="font-display text-3xl font-bold text-white">Гайды Genshin Impact</h1>
  <p class="mt-2 max-w-2xl text-teyvat-muted">
    Материалы по игре: когда крутить баннеры, что изменилось в обновлении, как прокачать аккаунт. Фильтры по типу статьи,
    теме и статусу актуальности — на клиенте; каждая статья доступна по своему постоянному адресу для Яндекса и Google.
  </p>

  <form
    class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3"
    method="get"
    action="/guides"
    role="search"
  >
    <label for="guide-search" class="sr-only">Поиск по гайдам</label>
    <input
      id="guide-search"
      type="search"
      name="q"
      data-guide-search
      value={initialSearchQ}
      maxlength="200"
      placeholder="Поиск по названию и описанию…"
      autocomplete="off"
      class="w-full rounded-full border border-white/15 bg-white/5 px-4 py-2.5 text-slate-100 placeholder:text-teyvat-muted focus:border-teyvat-mint/50 focus:outline-none focus:ring-1 focus:ring-teyvat-mint/30 sm:max-w-md"
    />
    <button
      type="submit"
      class="shrink-0 rounded-full bg-gradient-to-r from-teyvat-accent/40 to-teyvat-mint/25 px-6 py-2.5 text-sm font-bold text-teyvat-gold ring-1 ring-teyvat-accent/40 transition hover:brightness-110"
    >
      Найти
    </button>
  </form>

  <section class="mt-8 rounded-2xl border border-white/10 bg-white/5 p-6 text-slate-300">
    <h2 class="font-display text-lg font-semibold text-white">Связанные разделы</h2>
    <p class="mt-2 text-sm leading-relaxed">
      <a href="/characters" class="text-teyvat-mint underline-offset-2 hover:underline">Каталог персонажей Genshin Impact</a>
      {' '}— стихии, оружие и ссылки на билды. На{' '}
      <a href="/" class="text-teyvat-mint underline-offset-2 hover:underline">главной GenshinTop</a> собраны свежие гайды и популярные герои.
    </p>
  </section>

  <section class="mt-6 rounded-2xl border border-teyvat-accent/20 bg-teyvat-accent/5 p-6 text-slate-300">
    <h2 class="font-display text-lg font-semibold text-white">Тематические хабы (отдельные URL)</h2>
    <p class="mt-3 flex flex-wrap gap-x-3 gap-y-2 text-sm">
      <a href="/guides/banners" class="text-teyvat-mint underline-offset-2 hover:underline">Баннеры</a>
      <span class="text-teyvat-muted">·</span>
      <a href="/guides/patches" class="text-teyvat-mint underline-offset-2 hover:underline">Обновления</a>
      <span class="text-teyvat-muted">·</span>
      <a href="/guides/codes" class="text-teyvat-mint underline-offset-2 hover:underline">Промокоды</a>
      <span class="text-teyvat-muted">·</span>
      <a href="/guides/newbie" class="text-teyvat-mint underline-offset-2 hover:underline">Новичкам</a>
      <span class="text-teyvat-muted">·</span>
      <a href="/guides/economy" class="text-teyvat-mint underline-offset-2 hover:underline">Экономика</a>
      <span class="text-teyvat-muted">·</span>
      <a href="/guides/tier-list" class="text-teyvat-mint underline-offset-2 hover:underline">Тир-листы</a>
    </p>
  </section>

  <div class="mt-6 space-y-3">
    <p class="text-xs font-medium uppercase tracking-wide text-teyvat-muted">Тип (коллекция)</p>
    <div class="flex flex-wrap gap-2" data-guide-cats>
      {
        categories.map((c) => (
          <button
            type="button"
            data-cat={c.id}
            class:list={[
              'rounded-full border px-3 py-1.5 text-sm transition',
              c.id === ''
                ? 'border-teyvat-accent/60 bg-teyvat-accent/15 text-teyvat-gold'
                : 'border-white/15 bg-white/5 text-slate-200 hover:bg-white/10',
            ]}
          >
            {c.label}
          </button>
        ))
      }
    </div>
    <p class="text-xs font-medium uppercase tracking-wide text-teyvat-muted">Тема для игрока</p>
    <div class="flex flex-wrap gap-2" data-guide-topics>
      {
        topicFilters.map((c) => (
          <button
            type="button"
            data-topic={c.id}
            class:list={[
              'rounded-full border px-3 py-1.5 text-sm transition',
              c.id === ''
                ? 'border-teyvat-accent/60 bg-teyvat-accent/15 text-teyvat-gold'
                : 'border-white/15 bg-white/5 text-slate-200 hover:bg-white/10',
            ]}
          >
            {c.label}
          </button>
        ))
      }
    </div>
    <p class="text-xs font-medium uppercase tracking-wide text-teyvat-muted">Актуальность</p>
    <div class="flex flex-wrap gap-2" data-guide-status>
      {
        statusFilters.map((c) => (
          <button
            type="button"
            data-status={c.id}
            class:list={[
              'rounded-full border px-3 py-1.5 text-sm transition',
              c.id === ''
                ? 'border-teyvat-accent/60 bg-teyvat-accent/15 text-teyvat-gold'
                : 'border-white/15 bg-white/5 text-slate-200 hover:bg-white/10',
            ]}
          >
            {c.label}
          </button>
        ))
      }
    </div>
  </div>

  <p class="mb-4 mt-6 text-sm text-teyvat-muted">
    Показано: <span data-guide-count>{all.length}</span> из {all.length}
  </p>

  <div class="grid gap-4 md:grid-cols-2" id="guide-grid">
    {
      all.map((g) => {
        const slug = contentSlugFromId(g.id);
        const fileHint = `${slug}.md`;
        const cat = g.data.category as GuideCategory;
        const topic = effectiveGuideTopic(g.data.topic, cat, fileHint);
        const status = effectiveGuideStatus(g.data.status, cat, g.data.date, slug);
        const audience = effectiveGuideAudience(g.data.audience, cat);
        const gameVersion = effectiveGuideGameVersion(g.data.gameVersion, slug);
        return (
          <GuideCard
            title={g.data.title}
            slug={slug}
            category={g.data.category}
            topic={topic}
            status={status}
            audience={audience}
            gameVersion={gameVersion}
            date={g.data.date}
            updatedAt={g.data.updatedAt}
            summary={g.data.summary}
          />
        );
      })
    }
  </div>

  <script>
    const paintGroup = (root: string, attr: string, active: string) => {
      const wrap = document.querySelector(root);
      if (!wrap) return;
      const buttons = [...wrap.querySelectorAll('button')] as HTMLButtonElement[];
      for (const b of buttons) {
        const id = b.getAttribute(attr) ?? '';
        const on = id === active;
        b.classList.toggle('border-teyvat-accent/60', on);
        b.classList.toggle('bg-teyvat-accent/15', on);
        b.classList.toggle('text-teyvat-gold', on);
        b.classList.toggle('border-white/15', !on);
        b.classList.toggle('bg-white/5', !on);
        b.classList.toggle('text-slate-200', !on);
      }
    };

    const cards = () => [...document.querySelectorAll('[data-guide-card]')] as HTMLElement[];
    const countEl = document.querySelector('[data-guide-count]');
    let activeCat = '';
    let activeTopic = '';
    let activeStatus = '';

    function apply() {
      const input = document.querySelector('[data-guide-search]') as HTMLInputElement | null;
      const q = input?.value?.trim().toLowerCase() ?? '';
      let visible = 0;
      for (const el of cards()) {
        const cat = el.dataset.category ?? '';
        const topic = el.dataset.topic ?? '';
        const status = el.dataset.status ?? '';
        const hay = el.dataset.searchHaystack ?? '';
        const show =
          (!activeCat || cat === activeCat) &&
          (!activeTopic || topic === activeTopic) &&
          (!activeStatus || status === activeStatus) &&
          (!q || hay.includes(q));
        el.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      if (countEl) countEl.textContent = String(visible);
    }

    function repaintAll() {
      paintGroup('[data-guide-cats]', 'data-cat', activeCat);
      paintGroup('[data-guide-topics]', 'data-topic', activeTopic);
      paintGroup('[data-guide-status]', 'data-status', activeStatus);
      apply();
    }

    document.querySelector('[data-guide-cats]')?.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const btn = t.closest('button') as HTMLButtonElement | null;
      if (!btn) return;
      activeCat = btn.getAttribute('data-cat') ?? '';
      repaintAll();
    });

    document.querySelector('[data-guide-topics]')?.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const btn = t.closest('button') as HTMLButtonElement | null;
      if (!btn) return;
      activeTopic = btn.getAttribute('data-topic') ?? '';
      repaintAll();
    });

    document.querySelector('[data-guide-status]')?.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const btn = t.closest('button') as HTMLButtonElement | null;
      if (!btn) return;
      activeStatus = btn.getAttribute('data-status') ?? '';
      repaintAll();
    });

    document.querySelector('[data-guide-search]')?.addEventListener('input', () => {
      apply();
    });

    repaintAll();
  </script>
</BaseLayout>

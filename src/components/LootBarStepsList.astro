---
/** GRACE[M-WEBSITE][LootBarStepsList][BLOCK_LOOTBAR_STEPS] */
interface Props {
  steps: string[];
  id?: string;
}

const { steps, id = 'lootbar-steps' } = Astro.props;
---

<section class="not-prose mt-12" aria-labelledby={`${id}-heading`}>
  <h2 id={`${id}-heading`} class="font-display text-2xl font-bold text-white md:text-3xl">
    Как получить и применить купон
  </h2>
  <ol class="mt-6 space-y-4">
    {
      steps.map((text, i) => (
        <li class="flex gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-teyvat-accent/25 text-sm font-bold text-teyvat-gold">
            {i + 1}
          </span>
          <p class="text-slate-200 leading-relaxed">{text}</p>
        </li>
      ))
    }
  </ol>
</section>

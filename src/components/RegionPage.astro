---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { contentSlugFromId } from '../lib/slug';
import {
  SITE_URL,
  absoluteUrl,
  breadcrumbListSchema,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../lib/seo';

interface Section {
  heading: string;
  body: string;
}

interface Props {
  slug: string;
  name: string;
  archon: string;
  element: string;
  introduction: string;
  description: string;
  patchRange: string;
  keyMechanics: string[];
  archonQuestPath: string;
  sections: Section[];
  characterMatcher?: (name: string) => boolean;
}

const {
  slug,
  name,
  archon,
  element,
  introduction,
  description,
  patchRange,
  keyMechanics,
  archonQuestPath,
  sections,
  characterMatcher,
} = Astro.props;

const canonicalPath = `/regions/${slug}`;
const url = absoluteUrl(canonicalPath);

const allCharacters = await getCollection('characters');
const regionCharacters = characterMatcher
  ? allCharacters.filter((c) => characterMatcher(c.data.name))
  : [];

const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'Регионы Тейвата', href: '/regions' },
  { label: name, href: canonicalPath },
];

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  breadcrumbListSchema(breadcrumbs),
  {
    '@type': 'Place',
    '@id': `${url}#place`,
    name: `${name} (Genshin Impact)`,
    description,
    url,
    isPartOf: { '@id': `${SITE_URL}/#website` },
    additionalType: 'Region',
  },
  {
    '@type': 'Article',
    '@id': `${url}#article`,
    headline: `${name} — регион Genshin Impact`,
    description,
    inLanguage: 'ru-RU',
    url,
    author: { '@id': `${SITE_URL}/#editorial-team` },
    publisher: { '@id': `${SITE_URL}/#organization` },
  },
]);
---

<BaseLayout
  title={`${name} — регион Genshin Impact: персонажи, квесты, механики`}
  description={description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbs} />

  <article class="prose prose-invert prose-lg max-w-3xl prose-headings:font-display">
    <header class="mb-8 not-prose border-b border-white/10 pb-6">
      <p class="text-sm text-teyvat-muted">
        <span class="text-teyvat-gold">{element}</span>
        {' · Архонт: '}
        {archon}
        {' · '}
        {patchRange}
      </p>
      <h1 class="mt-2 font-display text-4xl font-bold text-white">{name}</h1>
      <p class="mt-3 text-teyvat-muted">{introduction}</p>
    </header>

    {
      keyMechanics.length > 0 ? (
        <section>
          <h2>Ключевые механики региона</h2>
          <ul>
            {keyMechanics.map((m) => (
              <li>{m}</li>
            ))}
          </ul>
        </section>
      ) : null
    }

    {
      sections.map((s) => (
        <section>
          <h2>{s.heading}</h2>
          <p>{s.body}</p>
        </section>
      ))
    }

    <section>
      <h2>Сюжет: квесты архонтов</h2>
      <p>
        Главный сюжет региона раскрывается через цепь квестов архонтов. Полная дорожная карта
        прохождения и порядок глав — в разделе{' '}
        <a href="/guides/quests">квесты архонтов</a>. Прямой путь в этот регион:{' '}
        <code>{archonQuestPath}</code>.
      </p>
    </section>

    {
      regionCharacters.length > 0 ? (
        <section class="not-prose">
          <h2 class="font-display text-2xl text-white">Персонажи региона</h2>
          <ul class="mt-4 grid list-none grid-cols-1 gap-2 p-0 sm:grid-cols-2">
            {regionCharacters.map((c) => (
              <li>
                <a
                  href={`/characters/${contentSlugFromId(c.id)}`}
                  class="block rounded-lg border border-white/10 bg-white/5 px-3 py-2 transition hover:border-teyvat-mint/40 hover:bg-white/10"
                >
                  <span class="block font-medium text-white">{c.data.name}</span>
                  <span class="block text-xs text-teyvat-muted">
                    {c.data.element} · {c.data.weapon}
                    {c.data.rarity ? ` · ${'★'.repeat(c.data.rarity)}` : ''}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }

    <section class="not-prose mt-10 rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="font-display text-lg text-white">Связанные разделы</h2>
      <ul class="mt-3 list-disc pl-5 text-sm text-slate-300">
        <li><a href="/regions" class="text-teyvat-mint hover:underline">Все регионы Тейвата</a></li>
        <li><a href="/guides/quests" class="text-teyvat-mint hover:underline">Квесты архонтов и сюжет</a></li>
        <li><a href="/guides/domains" class="text-teyvat-mint hover:underline">Подземелья и фарм</a></li>
        <li><a href="/guides/bosses" class="text-teyvat-mint hover:underline">Боссы Genshin Impact</a></li>
        <li><a href="/guides/patches" class="text-teyvat-mint hover:underline">Свежие патчи</a></li>
      </ul>
    </section>
  </article>
</BaseLayout>

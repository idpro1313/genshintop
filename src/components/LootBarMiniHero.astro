---
/**
 * GRACE[M-WEBSITE][LootBarMiniHero][BLOCK_LOOTBAR_MINI_HERO]
 * Компактный оффер-блок для подстраниц /lootbar/* (без агрессивного дубля на bezopasnost).
 */
import {
  lootbarCoupons,
  lootbarMaxDiscountPercent,
} from '../data/lootbar';
import LootBarOutboundLink from './LootBarOutboundLink.astro';
import { lootbarGenshinTopupUrl } from '../lib/partners';

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
const topupUrl = lootbarGenshinTopupUrl('lootbar_hub');
const maxCouponPct =
  lootbarCoupons.length > 0 ? Math.max(...lootbarCoupons.map((c) => c.percent)) : null;
---

<div
  class="not-prose mb-8 grid gap-6 rounded-2xl border border-white/15 bg-gradient-to-br from-teyvat-accent/15 via-teyvat-night to-teyvat-mint/10 p-6 md:grid-cols-2 md:items-center"
>
  <div>
    <p class="text-xs font-medium uppercase tracking-wide text-teyvat-muted">Партнёрский материал · LootBar.gg</p>
    <h1 class="mt-2 font-display text-2xl font-bold text-white md:text-3xl">{title}</h1>
    {subtitle ? <p class="mt-3 text-slate-300">{subtitle}</p> : null}
    <LootBarOutboundLink
      href={topupUrl}
      class="mt-5 inline-flex rounded-xl bg-teyvat-accent px-5 py-2.5 text-sm font-semibold text-teyvat-night transition hover:bg-teyvat-gold"
      reachGoal="lootbar_hero_cta"
    >
      Перейти на LootBar
    </LootBarOutboundLink>
  </div>
  <div class="rounded-xl border border-white/10 bg-white/[0.05] p-5 text-center md:text-left">
    {lootbarMaxDiscountPercent != null ? (
      <p class="font-display text-2xl font-bold text-teyvat-gold md:text-3xl">
        До {lootbarMaxDiscountPercent}% дешевле, чем в игре
      </p>
    ) : (
      <p class="text-lg font-semibold text-slate-200">Скидки и купоны — на витрине LootBar</p>
    )}
    {maxCouponPct != null ? (
      <p class="mt-2 text-sm text-teyvat-mint">+ купон до {maxCouponPct}%</p>
    ) : null}
  </div>
</div>

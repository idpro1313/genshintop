---
/**
 * Узкая плашка под шапкой: ведёт на внутренний раздел `/lootbar` (как на dandangers — баннер → страница с офферами).
 */
interface Props {
  /** Скрыть на самой странице раздела, чтобы не дублировать призыв. */
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<a
  href="/lootbar"
  class:list={[
    'group flex w-full items-center justify-center gap-2 border-b border-teyvat-accent/30 bg-gradient-to-r from-teyvat-accent/15 via-teyvat-night to-teyvat-mint/10 px-4 text-center transition hover:from-teyvat-accent/25 hover:to-teyvat-mint/15',
    compact ? 'py-1.5 text-xs sm:text-sm' : 'py-2.5 text-sm sm:text-base',
  ]}
  data-affiliate-banner="lootbar"
>
  <span class="font-medium text-teyvat-gold group-hover:text-white">LootBar.gg</span>
  <span class="hidden text-teyvat-muted sm:inline">—</span>
  <span class="text-slate-200 group-hover:text-white">
    {compact
      ? 'Пополнение Genshin Impact'
      : 'Выгодное пополнение Genshin Impact — скидки и кристаллы'}
  </span>
  <span
    class="rounded-full bg-white/10 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-teyvat-mint group-hover:bg-teyvat-accent/40 group-hover:text-teyvat-night"
  >
    Подробнее
  </span>
</a>

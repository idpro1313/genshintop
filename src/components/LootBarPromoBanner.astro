---
/**
 * Яркая плашка под шапкой: бренд, оффер из data-слоя, крупная CTA на LootBar.gg
 * (Метрика: lootbar_banner_click). Без слова «реклама» — мелкая ссылка
 * «партнёрская ссылка» ведёт на /partnership-disclosure.
 * GRACE[M-WEBSITE][LootBarPromoBanner][BLOCK_LOOTBAR_BANNER]
 */
import { lootbarMaxDiscountPercent } from '../data/lootbar';
import LootBarOutboundLink from './LootBarOutboundLink.astro';
import { lootbarGenshinTopupUrl } from '../lib/partners';

interface Props {
  /** Скрыть на самой странице раздела, чтобы не дублировать призыв. */
  compact?: boolean;
}

const { compact = false } = Astro.props;
const topupUrl = lootbarGenshinTopupUrl('lootbar_banner');

const hasNumber = lootbarMaxDiscountPercent != null;
const headline = hasNumber
  ? `До ${lootbarMaxDiscountPercent}% дешевле в Genshin Impact`
  : 'Скидки на топ-ап и купоны Genshin Impact';
const subline = hasNumber
  ? 'купоны и скидки на топ-ап'
  : 'промокоды и пакеты кристаллов на витрине LootBar';
---

<section
  role="complementary"
  aria-label="Партнёрский баннер LootBar.gg"
  data-affiliate-banner="lootbar"
  class:list={[
    'lootbar-banner relative isolate overflow-hidden border-y border-teyvat-accent/60 shadow-[0_0_24px_rgba(232,180,69,0.35)]',
    compact ? 'py-2' : 'py-3 sm:py-4',
  ]}
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(90deg,#1a1a2e_0%,rgba(232,180,69,0.55)_45%,rgba(78,205,196,0.45)_75%,#1a1a2e_100%)]"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_30%_50%,rgba(245,214,138,0.35),transparent_60%)]"
  ></div>

  <div
    class:list={[
      'mx-auto flex w-full max-w-6xl flex-wrap items-center justify-center gap-x-5 gap-y-2 sm:flex-nowrap',
      compact ? 'px-3 text-xs' : 'px-4 sm:px-6 text-sm sm:text-base',
    ]}
  >
    <a
      href="/lootbar"
      class="group flex shrink-0 items-center gap-2 font-display font-bold text-teyvat-gold drop-shadow transition hover:text-white"
    >
      <svg
        viewBox="0 0 24 24"
        class:list={[compact ? 'h-4 w-4' : 'h-5 w-5 sm:h-6 sm:w-6']}
        aria-hidden="true"
        fill="currentColor"
      >
        <path
          d="M12 1.6l2.6 6.4 6.9.6-5.2 4.6 1.6 6.8L12 16.4l-5.9 3.6 1.6-6.8L2.5 8.6l6.9-.6L12 1.6z"
        ></path>
      </svg>
      <span class:list={[compact ? 'text-sm' : 'text-base sm:text-lg']}>LootBar.gg</span>
    </a>

    <div class="hidden h-7 w-px shrink-0 bg-white/25 sm:block" aria-hidden="true"></div>

    <div class="min-w-0 flex-1 text-center sm:text-left">
      <p
        class:list={[
          'font-display font-extrabold leading-tight text-white drop-shadow',
          compact ? 'text-sm' : 'text-base sm:text-xl',
        ]}
      >
        {headline}
      </p>
      <p
        class:list={[
          'mt-0.5 leading-snug text-white/85',
          compact ? 'text-[0.7rem]' : 'text-xs sm:text-sm',
        ]}
      >
        {subline}
      </p>
    </div>

    <LootBarOutboundLink
      href={topupUrl}
      reachGoal="lootbar_banner_click"
      class:list={[
        'lootbar-cta-shine relative inline-flex shrink-0 items-center gap-2 overflow-hidden rounded-full bg-teyvat-night font-bold text-teyvat-gold ring-1 ring-teyvat-gold/60 shadow-[0_0_18px_rgba(245,214,138,0.45)] transition hover:scale-[1.03] hover:bg-black hover:text-white hover:shadow-[0_0_24px_rgba(245,214,138,0.7)]',
        compact ? 'px-4 py-1.5 text-xs' : 'px-5 py-2.5 text-sm sm:px-6 sm:py-3 sm:text-base',
      ]}
    >
      <span>Получить скидку</span>
      <svg
        viewBox="0 0 24 24"
        class:list={[compact ? 'h-3.5 w-3.5' : 'h-4 w-4 sm:h-5 sm:w-5']}
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="M13 5l7 7-7 7"></path>
      </svg>
    </LootBarOutboundLink>

    <a
      href="/partnership-disclosure"
      rel="noopener"
      class:list={[
        'shrink-0 text-[10px] font-medium uppercase tracking-wide text-white/45 transition hover:text-white/80',
        compact ? 'hidden sm:inline' : '',
      ]}
    >
      партнёрская ссылка
    </a>
  </div>
</section>

<style is:global>
  @keyframes lootbar-shine {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
  .lootbar-cta-shine::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
      120deg,
      transparent 30%,
      rgba(255, 255, 255, 0.18) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
    animation: lootbar-shine 4.5s linear infinite;
    pointer-events: none;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from './GuideCard.astro';
import { getCollection } from 'astro:content';
import { contentSlugFromId } from '../lib/slug';
import type { GuideCategory } from '../lib/guide-taxonomy';
import {
  effectiveGuideAudience,
  effectiveGuideGameVersion,
  effectiveGuideStatus,
  effectiveGuideTopic,
} from '../lib/guide-taxonomy';
import {
  matchHubBanners,
  matchHubCodes,
  matchHubEconomy,
  matchHubNewbie,
  matchHubPatches,
  matchHubTierList,
  type GuideEntry,
} from '../lib/guide-hub';
import {
  SITE_URL,
  absoluteUrl,
  jsonLdGraph,
  publisherOrganization,
  webSiteNode,
} from '../lib/seo';

type GuideHubId =
  | 'banners'
  | 'codes'
  | 'patches'
  | 'newbie'
  | 'economy'
  | 'tier-list';

interface Props {
  hub: GuideHubId;
  title: string;
  description: string;
  intro: string;
}

const { hub, title, description, intro } = Astro.props;

const canonicalPath = `/guides/${hub}`;

function matcher(entry: GuideEntry): boolean {
  switch (hub) {
    case 'banners':
      return matchHubBanners(entry);
    case 'codes':
      return matchHubCodes(entry);
    case 'patches':
      return matchHubPatches(entry);
    case 'newbie':
      return matchHubNewbie(entry);
    case 'economy':
      return matchHubEconomy(entry);
    case 'tier-list':
      return matchHubTierList(entry);
    default:
      return false;
  }
}

const allRaw = (await getCollection('guides')).filter(
  (e) => !e.data.sourceSlug.startsWith('_placeholder'),
);
const all = allRaw.filter(matcher).sort((a, b) => {
  const ta = (a.data.updatedAt ?? a.data.date)?.getTime() ?? 0;
  const tb = (b.data.updatedAt ?? b.data.date)?.getTime() ?? 0;
  return tb - ta;
});

const pageUrl = absoluteUrl(canonicalPath);
const itemListElement = all.map((g, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: g.data.title,
  item: absoluteUrl(`/guides/${contentSlugFromId(g.id)}`),
}));

const jsonLd = jsonLdGraph([
  publisherOrganization(),
  webSiteNode(),
  {
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    name: title,
    description,
    url: pageUrl,
    isPartOf: { '@id': `${SITE_URL}/#website` },
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: all.length,
      itemListElement,
    },
  },
]);

const hubLinks: Array<{ href: string; label: string }> = [
  { href: '/guides', label: 'Все гайды' },
  { href: '/guides/banners', label: 'Баннеры' },
  { href: '/guides/codes', label: 'Промокоды' },
  { href: '/guides/patches', label: 'Обновления' },
  { href: '/guides/newbie', label: 'Новичкам' },
  { href: '/guides/economy', label: 'Экономика' },
  { href: '/guides/tier-list', label: 'Тир-листы' },
];
---

<BaseLayout {title} {description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <h1 class="font-display text-3xl font-bold text-white">{title}</h1>
  <p class="mt-2 max-w-2xl text-teyvat-muted">{intro}</p>
  <nav class="mt-6 flex flex-wrap gap-2 text-sm" aria-label="Разделы гайдов">
    {
      hubLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'rounded-full border px-3 py-1 transition',
            href === canonicalPath
              ? 'border-teyvat-accent/60 bg-teyvat-accent/15 text-teyvat-gold'
              : 'border-white/15 text-slate-300 hover:border-teyvat-mint/40',
          ]}
        >
          {label}
        </a>
      ))
    }
  </nav>
  {
    hub === 'economy' ? (
      <p class="mt-6 rounded-2xl border border-teyvat-accent/20 bg-teyvat-accent/5 p-4 text-sm text-slate-300">
        Пополнение и сторонние сторы — отдельная тема с рисками. Коротко о партнёрском варианте:{' '}
        <a href="/lootbar" class="text-teyvat-mint underline-offset-2 hover:underline">
          раздел LootBar
        </a>
        . Подробнее о прозрачности:{' '}
        <a href="/partnership-disclosure" class="text-teyvat-mint underline-offset-2 hover:underline">
          раскрытие партнёрства
        </a>
        .
      </p>
    ) : null
  }
  <p class="mb-4 mt-8 text-sm text-teyvat-muted">Материалов в подборке: {all.length}</p>
  <div class="grid gap-4 md:grid-cols-2">
    {
      all.map((g) => {
        const slug = contentSlugFromId(g.id);
        const fileHint = `${slug}.md`;
        const cat = g.data.category as GuideCategory;
        return (
          <GuideCard
            title={g.data.title}
            slug={slug}
            category={g.data.category}
            topic={effectiveGuideTopic(g.data.topic, cat, fileHint, g.data.summary ?? '')}
            status={effectiveGuideStatus(g.data.status, cat, g.data.date, slug, g.data.summary ?? '')}
            audience={effectiveGuideAudience(g.data.audience, cat, g.data.summary ?? '')}
            gameVersion={effectiveGuideGameVersion(g.data.gameVersion, slug, g.data.summary ?? '')}
            date={g.data.date}
            updatedAt={g.data.updatedAt}
            summary={g.data.summary}
          />
        );
      })
    }
  </div>
</BaseLayout>

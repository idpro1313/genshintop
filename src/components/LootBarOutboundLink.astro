---
interface Props {
  href: string;
  class?: string;
  /** Имя цели Яндекс.Метрики (reachGoal). */
  reachGoal: string;
}

const { href, class: className, reachGoal } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer sponsored"
  class={className}
  data-reach-goal={reachGoal}
>
  <slot />
</a>

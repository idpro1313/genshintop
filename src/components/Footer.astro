        <ul class="mt-4 space-y-1 text-xs">
          <li><a href="/about" class="hover:text-teyvat-mint hover:underline">О проекте</a></li>
          <li><a href="/editorial-policy" class="hover:text-teyvat-mint hover:underline">Редакционная политика</a></li>

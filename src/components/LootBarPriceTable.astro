---
/**
 * GRACE[M-WEBSITE][LootBarPriceTable][BLOCK_LOOTBAR_PRICE_TABLE]
 * Таблица «в игре / LootBar» или честная заглушка.
 */
import type { LootBarPriceRow } from '../data/lootbar';
import LootBarOutboundLink from './LootBarOutboundLink.astro';
import { lootbarGenshinTopupUrl } from '../lib/partners';

interface Props {
  rows: LootBarPriceRow[];
  updatedAt: string | null;
}

const { rows, updatedAt } = Astro.props;
const topupUrl = lootbarGenshinTopupUrl('lootbar_table');
---

<section class="not-prose mt-12" aria-labelledby="lootbar-price-heading">
  <h2 id="lootbar-price-heading" class="font-display text-2xl font-bold text-white md:text-3xl">
    Сравнение цен
  </h2>
  {
    rows.length > 0 ? (
      <>
        <p class="mt-3 text-sm text-slate-400">
          {updatedAt ? (
            <>
              Данные ориентировочные на{' '}
              <time datetime={updatedAt}>{updatedAt}</time>. Проверьте итог в корзине LootBar перед оплатой.
            </>
          ) : (
            <>Проверяйте итоговую сумму в корзине LootBar перед оплатой.</>
          )}
        </p>
        <div class="mt-6 overflow-x-auto rounded-2xl border border-white/10">
          <table class="w-full min-w-[600px] text-left text-sm">
            <thead class="bg-white/[0.06] text-xs font-semibold uppercase tracking-wide text-teyvat-muted">
              <tr>
                <th class="px-4 py-3">Товар</th>
                <th class="px-4 py-3">В игре (ориентир), ₽</th>
                <th class="px-4 py-3">На LootBar, ₽</th>
                <th class="px-4 py-3">Экономия, ₽</th>
                <th class="px-4 py-3">%</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10 text-slate-200">
              {rows.map((row) => {
                const save = row.officialRub - row.lootbarRub;
                const pct = row.officialRub > 0 ? Math.round((save / row.officialRub) * 100) : 0;
                return (
                  <tr class="hover:bg-white/[0.02]">
                    <td class="px-4 py-3 font-medium text-white">{row.product}</td>
                    <td class="px-4 py-3">{row.officialRub.toLocaleString('ru-RU')}</td>
                    <td class="px-4 py-3 text-teyvat-mint">{row.lootbarRub.toLocaleString('ru-RU')}</td>
                    <td class="px-4 py-3">{save.toLocaleString('ru-RU')}</td>
                    <td class="px-4 py-3">{pct > 0 ? `${pct}%` : '—'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </>
    ) : (
      <div class="mt-6 rounded-2xl border border-dashed border-white/20 bg-white/[0.02] p-8 text-center">
        <p class="text-slate-300">
          Публичную таблицу цен мы обновим, когда получим согласованные строки от партнёра. Пока сравните пакеты
          прямо на витрине LootBar.
        </p>
        <LootBarOutboundLink
          href={topupUrl}
          class="mt-5 inline-flex rounded-xl bg-teyvat-accent px-6 py-3 font-semibold text-teyvat-night transition hover:bg-teyvat-gold"
          reachGoal="lootbar_table_cta"
        >
          Открыть витрину Genshin на LootBar
        </LootBarOutboundLink>
      </div>
    )
  }
</section>

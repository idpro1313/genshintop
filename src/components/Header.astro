---
const path = Astro.url.pathname;
const link = (href: string, label: string) => {
  const active = path === href || (href !== '/' && path.startsWith(href));
  return { href, label, active };
};
const nav = [
  link('/', 'Главная'),
  link('/characters', 'Персонажи'),
  link('/guides', 'Гайды'),
  link('/regions', 'Регионы'),
  link('/lootbar', 'Пополнение'),
  link('/about', 'О проекте'),
];
---

<header
  class="sticky top-0 z-50 border-b border-teyvat-accent/20 bg-teyvat-night/85 shadow-[0_4px_24px_rgba(0,0,0,0.35)] backdrop-blur-lg"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3.5">
    <a href="/" class="group flex min-h-[44px] min-w-[44px] items-center gap-2 py-1">
      <span class="font-display text-lg font-semibold tracking-wide text-gradient-gold group-hover:brightness-110"
        >GenshinTop</span
      >
      <span class="hidden rounded-full bg-white/5 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-teyvat-muted sm:inline"
        >genshintop.ru</span
      >
    </a>
    <nav class="flex flex-wrap items-center justify-end gap-1 sm:gap-2" aria-label="Основное меню">
      {
        nav.map(({ href, label, active }) => (
          <a
            href={href}
            class:list={[
              'rounded-full px-3.5 py-2.5 text-sm font-semibold transition-all duration-150 sm:px-4',
              active
                ? 'bg-gradient-to-r from-teyvat-accent/35 to-teyvat-mint/25 text-teyvat-gold shadow-[inset_0_0_0_1px_rgba(245,214,138,0.35)]'
                : 'text-slate-300 hover:bg-white/10 hover:text-white',
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

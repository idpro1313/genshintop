---
/**
 * GRACE[M-WEBSITE][LootBarCouponCard][BLOCK_LOOTBAR_COUPON_CARD]
 * Одна карточка купона; список собирает родитель.
 */
import type { LootBarCoupon } from '../data/lootbar';
import LootBarOutboundLink from './LootBarOutboundLink.astro';
import { lootbarGenshinTopupUrl } from '../lib/partners';

interface Props {
  coupon: LootBarCoupon;
}

const { coupon } = Astro.props;
const topupUrl = lootbarGenshinTopupUrl('lootbar_coupon');
---

<div
  class="not-prose flex flex-col rounded-2xl border border-white/15 bg-white/[0.04] p-5 shadow-lg shadow-black/20"
>
  <div class="flex items-start justify-between gap-3">
    <span class="rounded-full bg-teyvat-accent/25 px-3 py-1 text-xs font-bold text-teyvat-gold">{coupon.percent}%</span>
    {coupon.code ? (
      <span class="font-mono text-sm text-teyvat-mint">{coupon.code}</span>
    ) : null}
  </div>
  <h3 class="mt-3 text-lg font-semibold text-white">{coupon.title}</h3>
  <ul class="mt-3 space-y-1 text-sm text-slate-300">
    {coupon.maxDiscountRub != null ? (
      <li>
        Лимит скидки: до {coupon.maxDiscountRub.toLocaleString('ru-RU')} ₽
      </li>
    ) : null}
    {coupon.minOrderRub != null ? (
      <li>
        Минимальный заказ: от {coupon.minOrderRub.toLocaleString('ru-RU')} ₽
      </li>
    ) : null}
    {coupon.validDays != null ? <li>Срок: до {coupon.validDays} дн.</li> : null}
    {coupon.conditions.map((line) => (
      <li>{line}</li>
    ))}
  </ul>
  <div class="mt-5 flex flex-wrap gap-2">
    <LootBarOutboundLink
      href={topupUrl}
      class="inline-flex flex-1 items-center justify-center rounded-xl bg-teyvat-accent px-4 py-2.5 text-center text-sm font-semibold text-teyvat-night transition hover:bg-teyvat-gold sm:flex-none"
      reachGoal="lootbar_coupon_cta"
    >
      Активировать на LootBar
    </LootBarOutboundLink>
    {coupon.code ? (
      <button
        type="button"
        class="rounded-xl border border-white/20 px-4 py-2.5 text-sm font-medium text-white transition hover:border-teyvat-mint/40 hover:bg-white/5"
        data-reach-goal="lootbar_coupon_copy"
        onclick={`void navigator.clipboard.writeText(${JSON.stringify(coupon.code)});`}
      >
        Копировать код
      </button>
    ) : null}
  </div>
</div>
